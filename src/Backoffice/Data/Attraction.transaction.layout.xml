<layout type="Web">
	<view>
		<responsive name="MainTable" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100,&quot;offset&quot;:0}],[{&quot;width&quot;:100,&quot;offset&quot;:0}],[{&quot;width&quot;:100,&quot;offset&quot;:0}]]}]">
			<row>
				<cell>
					<responsive name="TitleContainer" class="title-container" responsiveSizes="[]">
						<row>
							<cell>
								<label name="Title" caption="Attraction" class="heading-01" />
							</cell>
						</row>
						<row>
							<cell>
								<errorviewer name="ErrorViewer" />
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
			<row>
				<cell>
					<responsive name="FormContainer" class="form-container" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:75,&quot;offset&quot;:25}],[{&quot;width&quot;:100,&quot;offset&quot;:0}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
						<row>
							<cell name="ToolbarCell" class="form__toolbar-cell">
								<actiongroup name="Toolbar" />
							</cell>
						</row>
						<row>
							<cell class="form__cell-advanced">
								<input attribute="AttractionId" labelCaption="=AttractionId.ContextualTitle" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="AttractionName" labelCaption="=AttractionName.ContextualTitle" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="AttractionDescription" labelCaption="=AttractionDescription.ContextualTitle" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="AttractionPhoto" labelCaption="=AttractionPhoto.ContextualTitle" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="CategoryId" labelCaption="=CategoryId.Title" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="CategoryName" labelCaption="=CategoryName.Title" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="CountryId" labelCaption="=CountryId.Title" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="CountryName" labelCaption="=CountryName.Title" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="CityId" labelCaption="=CityId.Title" />
							</cell>
						</row>
						<row>
							<cell class="form__cell">
								<input attribute="CityName" labelCaption="=CityName.Title" />
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
			<row>
				<cell class="form__actions--fixed" horizontalAlignment="Right" verticalAlignment="Middle">
					<actiongroup name="FormButtons" />
				</cell>
			</row>
		</responsive>
		<actiongroups>
			<actiongroup name="FormButtons" class="">
				<item>
					<action name="btn_enter" onClickEvent="Enter" caption="GX_BtnEnter" class="Button button-primary" />
				</item>
				<item>
					<action name="btn_cancel" onClickEvent="Cancel" caption="GX_BtnCancel" class="Button button-tertiary" />
				</item>
				<item>
					<action name="btn_delete" onClickEvent="Delete" caption="GX_BtnDelete" class="Button button-tertiary" />
				</item>
			</actiongroup>
			<actiongroup name="Toolbar">
				<item>
					<actiongroup name="NavButtons">
						<item>
							<action name="btn_first" onClickEvent="First" caption="" class="Button button-auxiliary ico__arrow-first" />
						</item>
						<item>
							<action name="btn_previous" onClickEvent="Previous" caption="" class="Button button-auxiliary ico__arrow-prev" />
						</item>
						<item>
							<action name="btn_next" onClickEvent="Next" caption="" class="Button button-auxiliary ico__arrow-next" />
						</item>
						<item>
							<action name="btn_last" onClickEvent="Last" caption="" class="Button button-auxiliary ico__arrow-last" />
						</item>
						<item>
							<action name="btn_select" onClickEvent="Select" caption="GX_BtnSelect" class="Button button-secondary" />
						</item>
					</actiongroup>
				</item>
			</actiongroup>
		</actiongroups>
	</view>
</layout>