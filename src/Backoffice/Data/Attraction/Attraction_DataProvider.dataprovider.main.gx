DataProvider Attraction_DataProvider
{
	AttractionCollection{
	
		Attraction
		where find(AttractionId, AttractionName="Louvre Museum",0) = 0
		{
			AttractionName = "Louvre Museum"
			AttractionDescription = "The Louvre in Paris is the world's largest art museum. It's home to the Mona Lisa, the Venus de Milo, and many other masterpieces."
			CategoryId = find(CategoryId, CategoryName = "Museum")
			CountryId = find(CountryId, CountryName = "France")
			CityId = find(CityId, CityName = "Paris")
			AttractionPhoto = LouvreMuseum.Link()
		}
	
	
		Attraction
		where find(AttractionId, AttractionName="The Great Wall",0) = 0
		{
			AttractionName = "The Great Wall"
			AttractionDescription = "The Great Wall of China is a vast ancient structure stretching over 21,000 km, symbolizing China's rich history and defense legacy."
			//AttractionEmbedding = AttractionEmbedding.GenerateEmbedding(AttractionName + ' ' + AttractionDescription + ' ' + CategoryName + ' ' + CountryName + ' ' + CityName, &Messages)
			CategoryId = find(CategoryId, CategoryName = "Historical Site")
			CountryId = find(CountryId, CountryName = "China")
			CityId = find(CityId, CityName = "Beijing")    
			AttractionPhoto = GreatWall.Link()
		}
	
		Attraction
		where find(AttractionId, AttractionName="Eiffel Tower",0) = 0
		{
			AttractionName = "Eiffel Tower"
			AttractionDescription = "The Eiffel Tower is an iconic iron structure in Paris, offering panoramic views and symbolizing France's culture and history."
			CategoryId = find(CategoryId, CategoryName = "Historical Site")
			CountryId = find(CountryId, CountryName = "France")
			CityId = find(CityId, CityName = "Paris")
			AttractionPhoto = EiffelTower.Link()
		}    
	
		Attraction
		where find(AttractionId, AttractionName="Christ the Redeemer",0) = 0
		{
			AttractionName = "Christ the Redeemer"
