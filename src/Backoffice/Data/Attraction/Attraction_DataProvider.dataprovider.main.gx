			CategoryId = find(CategoryId, CategoryName = "Historical Site")
			CountryId = find(CountryId, CountryName = "Brazil")
			CityId = find(CityId, CityName = "Rio de Janeiro")
			AttractionPhoto = ChristTheRedeemer.Link()
		}    
	
	
