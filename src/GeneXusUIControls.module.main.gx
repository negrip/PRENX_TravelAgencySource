Module GeneXusUIControls
{
	<ExportFile><Objects><Object parentGuid="45218f18-ebad-44af-9aa3-705ed3309379" user="GeneXus" versionDate="2025-10-06T15:27:57.0000000Z" lastUpdate="2023-03-24T16:15:43.0000000Z" checksum="da605e114c5de0af44d9b8e7ee7ac756" server_checksum="5b2fad2ee9865dedc82c9995f55579e4" fullyQualifiedName="GeneXusUIControls.IntersectionObserver.IntersectionObserver" moduleGuid="45218f18-ebad-44af-9aa3-705ed3309379" guid="ec25a4f3-1047-4b63-ae72-bdb815d055ec" name="IntersectionObserver" type="562f4793-aabe-449f-8821-fc77e550698e" description="Intersection Observer" parent="GeneXusUIControls.IntersectionObserver" parentType="c88fffcd-b6f8-0000-8fec-00b5497e2117"><Part type="3dd92fe7-b095-44d3-9fa0-8488fa3f0c67"><Source>{{=&lt;% %&gt;=}}

	&lt;ch-intersection-observer

	  [bottomMargin]="BottomRootMargin"

	  [leftMargin]="LeftRootMargin"

	  [rightMargin]="RightRootMargin"

	  [threshold]="Threshold"

	  [topMargin]="TopRootMargin"

	  (intersectionUpdate)="

	    IntersectionRatio = $event.detail.intersectionRatio * 100; handleIntersectionUpdate($event)

	  "

	&gt;

	  &lt;slot name="content"/&gt;

	&lt;/ch-intersection-observer&gt;

	

	&lt;style&gt;

	  :host {

	    display: contents;

	  }

	&lt;/style&gt;</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="8e9e4a7c-a4d3-4c36-8e8e-fb6702402f63"><Source>&lt;Definition auto="false" target="Angular"&gt;

		&lt;Property Name="TopRootMargin" Type="string" Scope="DesignTime" Default="0dip"/&gt;

	

		&lt;Property Name="RightRootMargin" Type="string" Scope="DesignTime" Default="0dip"/&gt;

	

		&lt;Property Name="BottomRootMargin" Type="string" Scope="DesignTime" Default="0dip"/&gt;

	

		&lt;Property Name="LeftRootMargin" Type="string" Scope="DesignTime" Default="0dip"/&gt;

	

		&lt;Property Name="Threshold" Type="string" Scope="DesignTime"/&gt;

	

		&lt;Property Name="IntersectionRatio" Type="numeric" Scope="RunTime" Default="0"/&gt;

	

		&lt;Event Name="IntersectionUpdate" On="intersectionUpdate" /&gt;

	&lt;/Definition&gt;</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="babf62c5-0111-49e9-a1c3-cc004d90900a"><InnerHtml>&lt;H1 class=page-title&gt;Intersection Observer&lt;/H1&gt;&lt;/HEADER&gt;

	&lt;DIV class=page-body&gt;&lt;FIGURE id=76979060-f539-49b4-856f-3a0cd192161d class="block-color-gray_background callout" style="WHITE-SPACE: pre-wrap; DISPLAY: flex"&gt;

	&lt;DIV style="FONT-SIZE: 1.5em"&gt;&lt;SPAN class=icon&gt;💡&lt;/SPAN&gt;&lt;/DIV&gt;

	&lt;DIV style="WIDTH: 100%"&gt;This control allows the user to wrap another component and use the Javascript Intersection Observer on it.&lt;/DIV&gt;&lt;/FIGURE&gt;

	&lt;H2 id=c491e685-09bb-42db-9027-f3d11512285a&gt;Properties:&lt;/H2&gt;

	&lt;UL id=6514cfdc-450b-40d7-b1bc-f25e3ad12ee8 class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;Root:&lt;/STRONG&gt;&lt;/MARK&gt; String: Set the ID of the component that is used as the viewport, default is the browser.&lt;/LI&gt;&lt;/UL&gt;

	&lt;H3 id=22efe259-70c4-4335-8818-133f7bb685a3&gt;Root Margin&lt;/H3&gt;

	&lt;P id=7ce80f29-9f97-4f66-b8cf-c675bbbf2540&gt;Margin around the root. The values can be percentages or dip, default value is zero. 

	&lt;DIV class=indented&gt;

	&lt;UL id=357e73e6-919c-4a1d-a018-2736be624cfd class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;TopRootMargin: &lt;/STRONG&gt;&lt;/MARK&gt;Top margin around the root&lt;/LI&gt;&lt;/UL&gt;

	&lt;UL id=d062796e-85d8-44b3-ba35-aa92b64a60c5 class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;/MARK&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;LeftRootMargin: &lt;/STRONG&gt;&lt;/MARK&gt;Left margin around the root&lt;/LI&gt;&lt;/UL&gt;

	&lt;UL id=ddeec778-03b2-4beb-b0b4-c449abc4833d class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;/MARK&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;BottomRootMargin: &lt;/STRONG&gt;&lt;/MARK&gt;Bottom margin around the root&lt;/LI&gt;&lt;/UL&gt;

	&lt;UL id=383fc262-a0b4-4e7c-9d96-c0fd688964d8 class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;/MARK&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;RightRootMargin: &lt;/STRONG&gt;&lt;/MARK&gt;Right margin around the root&lt;/LI&gt;&lt;/UL&gt;&lt;/DIV&gt;

	&lt;P&gt;&lt;/P&gt;

	&lt;UL id=5d470360-803f-4d21-bd16-1d39e64c8de2 class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;Threshold:&lt;/STRONG&gt;&lt;/MARK&gt; An string of colon separated&amp;nbsp;percentage values&amp;nbsp;which indicate at what percentage of the target's visibility the observer's callback should be executed, default is [0]. Example "10%,50%"&lt;/LI&gt;&lt;/UL&gt;

	&lt;UL id=36308b4f-5a91-43c5-8e68-7f87584f6ec8 class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;IntersectionRatio:&lt;/STRONG&gt;&lt;/MARK&gt; The degree of intersection between the target element and its root, its a read-only property that change its value when the &lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;IntersectionUpdate&lt;/STRONG&gt;&lt;/MARK&gt; event its triggered. Default value is zero.&lt;/LI&gt;&lt;/UL&gt;

	&lt;H2 id=d2439906-c7c5-4481-b0f4-e8e8ba8e6a7c&gt;Events:&lt;/H2&gt;

	&lt;UL id=96ec6739-87d5-4806-a583-7c1a145547ea class=bulleted-list&gt;

	&lt;LI style="LIST-STYLE-TYPE: disc"&gt;&lt;MARK class=highlight-gray_background&gt;&lt;STRONG&gt;IntersectionUpdate:&lt;/STRONG&gt;&lt;/MARK&gt; This event is triggered when the page load, and every time that an intercepton occurs.&lt;/LI&gt;&lt;/UL&gt;

	&lt;P id=7f9b875d-670b-42d9-b507-0c7faf0aea9c&gt;&lt;/P&gt;&lt;/DIV&gt;&lt;/ARTICLE&gt;</InnerHtml><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Properties><Property><Name>Name</Name><Value>IntersectionObserver</Value></Property><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Object><Object parentGuid="ab5f1405-0a35-4384-ada7-5398890b865e" user="GeneXus" versionDate="2025-10-06T15:27:57.0000000Z" lastUpdate="2023-03-24T16:15:21.0000000Z" checksum="7596b32c33061788ea70448728bc7153" server_checksum="2184c825d48784de76a9e25d6008bca3" fullyQualifiedName="GeneXusUIControls.IntersectionObserver" moduleGuid="ab5f1405-0a35-4384-ada7-5398890b865e" guid="45218f18-ebad-44af-9aa3-705ed3309379" name="IntersectionObserver" type="c88fffcd-b6f8-0000-8fec-00b5497e2117" description="Intersection Observer" parent="GeneXusUIControls" parentType="c88fffcd-b6f8-0000-8fec-00b5497e2117" PackagedModuleName="IntersectionObserver" moduleVersion="1.0"><Part type="ed1b7b1c-2aaf-46eb-9ec5-db348f6fa3fc"><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="babf62c5-0111-49e9-a1c3-cc004d90900a"><InnerHtml></InnerHtml><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Properties><Property><Name>Name</Name><Value>IntersectionObserver</Value></Property><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Object><Object parentGuid="42e3315c-dc6e-4b3d-8803-0853b8963f10" user="GeneXus" versionDate="2025-10-06T15:27:57.0000000Z" lastUpdate="2025-08-18T16:46:22.0000000Z" checksum="638dc54db6ba3b538319ff4204bc1a8b" server_checksum="380ada5e680c8169e6d69dfd022ccd12" fullyQualifiedName="GeneXusUIControls.Chat.TranslationsProvider" moduleGuid="42e3315c-dc6e-4b3d-8803-0853b8963f10" guid="a821b114-e394-4236-bd1a-3ab86bcc3d19" name="TranslationsProvider" type="2a9e9aba-d2de-4801-ae7f-5e3819222daf" description="T