ponseButton" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="stop Response Button" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>stopResponseButton</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>bas:VarChar</Value></Property><Property><Name>Length</Name><Value>50</Value></Property><Property><Name>AttMaxLen</Name><Value>50</Value></Property></Properties></Item><Item guid="0cbb33af-6691-4633-8142-2597984f7a24" name="error" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="error" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>error</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>bas:VarChar</Value></Property><Property><Name>Length</Name><Value>100</Value></Property><Property><Name>AttMaxLen</Name><Value>100</Value></Property></Properties></Item><Item guid="464c7759-5995-4860-a625-87e8aa47610b" name="sourceFiles" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="source Files" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>sourceFiles</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>bas:VarChar</Value></Property><Property><Name>Length</Name><Value>50</Value></Property><Property><Name>AttMaxLen</Name><Value>50</Value></Property></Properties></Item></Level></Level><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="babf62c5-0111-49e9-a1c3-cc004d90900a"><InnerHtml></InnerHtml><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Properties><Property><Name>Name</Name><Value>Translations</Value></Property><Property><Name>ExternalNamespace</Name><Value>GeneXus</Value></Property><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Object><Object parentGuid="42e3315c-dc6e-4b3d-8803-0853b8963f10" user="GeneXus" versionDate="2025-10-06T15:27:57.0000000Z" lastUpdate="2025-08-15T19:49:34.0000000Z" checksum="3f8fd25a8559d305fce35d7eb3893fd5" server_checksum="7e23fd1ce7b114c88de29ca5f11c8a3b" fullyQualifiedName="GeneXusUIControls.Chat.MessageUI" moduleGuid="42e3315c-dc6e-4b3d-8803-0853b8963f10" guid="a97cac02-81f0-4086-ba08-495130957cb4" name="MessageUI" type="447527b5-9210-4523-898b-5dccb17be60a" description="Message UI" parent="GeneXusUIControls.Chat" parentType="c88fffcd-b6f8-0000-8fec-00b5497e2117"><Part type="5c2aa9da-8fc4-4b6b-ae02-8db4fa48976a"><Level Name="MessageUI"><LevelInfo guid="1b52c288-99b9-4483-8e7e-d036b79734dd" name="MessageUI" type="a76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="Message UI" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>MessageUI</Value></Property></Properties></LevelInfo><Item guid="8724777a-2d10-4d43-9f71-911f3bad975f" name="id" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="id" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>id</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>bas:Character</Value></Property></Properties></Item><Item guid="aba341c4-0809-4fae-82a4-97a6d980799e" name="role" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="role" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>role</Value></Property><Property><Name>idBasedOn</Name><Value>Domain:MessageRole, GeneXusUIControls.Chat</Value></Property></Properties></Item><Item guid="457e0baa-7bcd-436d-abd7-b3de1b7b53a9" name="content" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="content" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>content</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>bas:Character</Value></Property></Properties></Item><Level Name="sources"><LevelInfo guid="79ffb4c7-a6d2-40ec-9640-16a7c51aff7b" name="sources" type="a76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="sources" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>sources</Value></Property><Property><Name>AttCollection</Name><Value>True</Value></Property><Property><Name>idCollectionItemName</Name><Value>source</Value></Property></Properties></LevelInfo><Item guid="1253c021-0aa9-412c-a402-0c367cd8b743" name="url" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="url" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>url</Value></Property><Property><Name>idBasedOn</Name><Value>Domain:Url, GeneXus</Value></Property></Properties></Item><Item guid="83c293d7-b205-4086-8313-10019a1c6440" name="caption" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="caption" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>caption</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>bas:Character</Value></Property></Properties></Item><Item guid="88674d6d-218b-41de-89bd-c1a08651d6f8" name="accessibleName" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="accessible Name" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>accessibleName</Value></Property><Property><Name>ATTCUSTOMTYPE</Name><Value>bas:Character</Value></Property></Properties></Item></Level><Item guid="f3131ba9-12a0-488a-b89e-ff44f3d69bad" name="status" type="f76e9340-bdb9-445d-8f81-cfd4ddd0b0f3" description="status" user="gxms-0001\root"><Properties><Property><Name>Name</Name><Value>status</Value></Property><Property><Name>idBasedOn</Name><Value>Domain:MessageStatus, GeneXusUIControls.Chat</Value></Property></Properties></Item></Level><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="babf62c5-0111-49e9-a1c3-cc004d90900a"><InnerHtml></InnerHtml><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Properties><Property><Name>Name</Name><Value>MessageUI</Value></Property><Property><Name>ExternalNamespace</Name><Value>GeneXus</Value></Property><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Object><Object parentGuid="42e3315c-dc6e-4b3d-8803-0853b8963f10" user="GeneXus" versionDate="2025-10-06T15:27:57.0000000Z" lastUpdate="2025-08-21T17:41:42.0000000Z" checksum="79b6c132006d49e2e93247c2d0842e5a" server_checksum="f38547af3aee65ceff467b13a4aac93a" fullyQualifiedName="GeneXusUIControls.Chat.Chat" moduleGuid="42e3315c-dc6e-4b3d-8803-0853b8963f10" guid="10475910-0549-4a75-b157-1adb280b0c83" name="Chat" type="562f4793-aabe-449f-8821-fc77e550698e" description="Chat" parent="GeneXusUIControls.Chat" parentType="c88fffcd-b6f8-0000-8fec-00b5497e2117"><Part type="3dd92fe7-b095-44d3-9fa0-8488fa3f0c67"><Source>

	Sub-Template Angular

		{{=&lt;% %&gt;=}}

		@defer (when translationsReady) {

			&lt;ch-theme

				[avoidFlashOfUnstyledContent]="false"

				[model]="themeModel"

			&gt;

			&lt;/ch-theme&gt;

			&lt;ch-chat

				##chatComponent

				[class]="Class" 

				[translations]="Translations"

				[items]="itemsProxy"

				[loadingState] = "'all-records-loaded'"

				[waitingResponse] = "WaitingResponse"

				[sendButtonDisabled] = "WaitingResponse"

				[showAdditionalContent]="ShowAdditionalContent"

				[autoScroll]="AutoScroll"

				[newUserMessageAlignment]="NewUserMessageAlignment"

				[newUserMessageScrollBehavior]="NewUserMessageScrollBehavior"

				[callbacks]="callbacks"

				[sendContainerLayout]="sendContainerLayout"

				[markdownTheme]="markdownTheme"

			&gt;

				&lt;%#ShowEmptyChatContent%&gt;

				&lt;div slot="empty-chat"&gt;

					&lt;slot name="EmptyChat" /&gt;

				&lt;/div&gt;

				&lt;%/ShowEmptyChatContent%&gt;

				&lt;%#ShowAdditionalContent%&gt;

				&lt;div slot="additional-content"&gt;

					&lt;slot name="AdditionalContent" /&gt;

				&lt;/div&gt;

				&lt;%/ShowAdditionalContent%&gt;

			&lt;/ch-chat&gt;

		}

	EndSub

	

	Sub-Template Web

		&lt;ch-theme avoid-flash-of-unstyled-content="false"&gt;&lt;/ch-theme&gt;

		&lt;ch-chat

			class="{{Class}}" 

			show-additional-content="{{ShowAdditionalContent}}"

			auto-scroll="{{AutoScroll}}"

			new-user-message-alignment="{{NewUserMessageAlignment}}"

			new-user-message-scroll-behavior="{{NewUserMessageScrollBehavior}}"

		&gt;

			{{#ShowEmptyChatContent}}

			&lt;div slot="empty-chat"&gt;

				&lt;slot name="EmptyChat" /&gt;

			&lt;/div&gt;

			{{/ShowEmptyChatContent}}

			{{#ShowAdditionalContent}}

			&lt;div slot="additional-content"&gt;

				&lt;slot name="AdditionalContent" /&gt;

			&lt;/div&gt;

			{{/ShowAdditionalContent}}

		&lt;/ch-chat&gt;

	EndSub</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="8e9e4a7c-a4d3-4c36-8e8e-fb6702402f63"><Source>&lt;Definition version="2.0"&gt;

		&lt;Properties&gt;

			&lt;Properties Name="Appearance"&gt;

				&lt;Property Name="Class" Type="class" Default="chat" /&gt;

				&lt;Property Name="MarkdownStyle" Type="KBObject" FilterType="DesignSystem" /&gt;

				&lt;Property Name="ShowEmptyChatContent" Type="boolean" Default="true" Scope="DesignTime" /&gt;

				&lt;Property Name="ShowAdditionalContent" Type="boolean" Default="false" Scope="DesignTime" /&gt;

			&lt;/Properties&gt;

			

			&lt;Properties Name="Behavior"&gt;

				&lt;Property Name="WaitingResponse" Type="boolean" Default="false" Scope="Runtime" /&gt;

			

				&lt;Property Name="AutoScroll" Type="string" Default="never"&gt;

					&lt;Values&gt;

						&lt;Value Description="Never"&gt;never&lt;/Value&gt;

						&lt;Value Description="At scroll end"&gt;at-scroll-end&lt;/Value&gt;

					&lt;/Values&gt;

				&lt;/Property&gt;

				

				&lt;Property Name="NewUserMessageAlignment" Type="string" Default="start"&gt;

					&lt;Values&gt;

						&lt;Value Description="Start"&gt;start&lt;/Value&gt;

						&lt;Value Description="End"&gt;end&lt;/Value&gt;

					&lt;/Values&gt;

				&lt;/Property&gt;

				

				&lt;Property Name="NewUserMessageScrollBehavior" Type="string" Default="smooth"&gt;

					&lt;Values&gt;

						&lt;Value Description="Instant"&gt;instant&lt;/Value&gt;

						&lt;Value Description="Smooth"&gt;smooth&lt;/Value&gt;

					&lt;/Values&gt;

				&lt;/Property&gt;

			&lt;/Properties&gt;

			

			&lt;Properties Name="Data Binding"&gt;

				&lt;Property Name="Messages" Type="variable" FilterType="UIControls.Chat.ChatMessageUI" /&gt;

				&lt;Property Name="Translations" Type="variable" FilterType="UIControls.Chat.Translations" /&gt;

			&lt;/Properties&gt;

	

			&lt;Properties Name="Handlers"&gt;

				&lt;Property Name="SendHistoryMessages" Type="boolean" Default="true" /&gt;

				&lt;Property Name="SendMessageHandlerUrl" Type="string" Scope="Runtime" /&gt;

				&lt;Property Name="SendMessageHandlerObject" Type="KBObject" FilterType="Procedure" /&gt;

			&lt;/Properties&gt;

		&lt;/Properties&gt;

	

		&lt;Methods&gt;

			&lt;Method Name="Send"&gt;

				&lt;Parameters&gt;

					&lt;Parameter Name="content" Type="string" /&gt;

				&lt;/Parameters&gt;

			&lt;/Method&gt;

			&lt;Method Name="StopResponse" /&gt;

	

			&lt;Method Name="AddNewMessage"&gt;

				&lt;Parameters&gt;

					&lt;Parameter Name="message" Type="sdt" /&gt;

				&lt;/Parameters&gt;

			&lt;/Method&gt;

			&lt;Method Name="UpdateLastMessage"&gt;

				&lt;Parameters&gt;

					&lt;Parameter Name="message" Type="sdt" /&gt;

					&lt;Parameter Name="mode" Type="string" Optional="true" Description="'replace' | 'concat'" /&gt;

				&lt;/Parameters&gt;

			&lt;/Method&gt;

		&lt;/Methods&gt;

		

	  	&lt;Events&gt;

			&lt;Event Name="SendMessage" /&gt;

			&lt;Event Name="MessageSent" /&gt;

			&lt;Event Name="ResponseCompleted" /&gt;

			&lt;Event Name="ResponseStopped" /&gt;

			&lt;Event Name="ResponseError" /&gt;

			&lt;Event Name="ConnectionFailed" /&gt;

		&lt;/Events&gt;

	  

		&lt;Settings&gt;

			&lt;Toolbox&gt;

				&lt;Name&gt;Chat&lt;/Name&gt;

				&lt;Categories&gt;

					&lt;Category&gt;GeneXusUIControls&lt;/Category&gt;

				&lt;/Categories&gt;

			&lt;/Toolbox&gt;

					

			&lt;Variables&gt;

				&lt;Variable

					Name="chatMessages"

					Type="MessageUI, GeneXusUIControls.Chat"

					Collection="true"

					SetProperty="Messages"

				/&gt;

				&lt;Variable

					Name="chatTranslations"

					Type="Translations, GeneXusUIControls.Chat"

					SetProperty="Translations"

				/&gt;

			&lt;/Variables&gt;

			

			&lt;Properties&gt;

				&lt;Property Name="MarkdownStyle" Value="GeneXusUnanimo.Markdown" /&gt;

			&lt;/Properties&gt;

			

			&lt;Sources&gt;

				&lt;Script type="code-snippet"&gt;

					//Sub 'StartChat'

					//	&amp;chatTranslations = GeneXusUIControls.Chat.TranslationsProvider()

					//EndSub

				&lt;/Script&gt;		

			&lt;/Sources&gt;

		&lt;/Settings&gt;

		

	 	&lt;Platforms&gt;

			&lt;Platform Name="Angular"&gt;

				&lt;ScreenTemplate Name="Angular" /&gt;

				

				&lt;Dependencies&gt;

					&lt;Dependency Type="npm" name="@genexus/chameleon-controls-library" version="6.20.1" /&gt;

				&lt;/Dependencies&gt;

			

				&lt;Sources&gt;

					&lt;Script Type="ng-component-import" Name="Imports"&gt;

						import { ViewChild, ElementRef, SimpleChanges} from "@angular/core";

						import { GeneXusSDNetwork } from '@genexus/web-standard-functions/dist/lib-esm/gxcore/sd/network';

						import { ChangeDetectorRef, inject} from "@angular/core";

					&lt;/Script&gt;

					

					&lt;Script Type="ng-component-classbody" Name="Body"&gt;

						@ViewChild('chatComponent', { static: false }) chatRef?: ElementRef;

						protected cdr = inject(ChangeDetectorRef);

						themeModel: any;

						itemsProxy: any;

						callbacks: any;

						sendContainerLayout: any;

						markdownTheme: string = null;

						fetchController: AbortController; 

						get translationsReady(): boolean {

							return (

								this.Translations.text &amp;&amp; 

								this.Translations.placeholder &amp;&amp; 

								this.Translations.accessibleName

							);

						}

						

						ngOnChanges(changes: SimpleChanges) {

							if (changes['Messages'] &amp;&amp; this.Messages) {

								this.itemsProxy = this.#createProxy();

							}

						}

						

						##sendChat = () =&gt; {

							if (this.SendMessageHandlerUrl) {

								this.#sendChatHandler();

							} else {

								this.#sendChatEvent();

							}

						}

						

						##sendChatEvent = () =&gt; {

							this.SendMessage();

						}

						

						##sendChatHandler = async () =&gt; {

							const messages = [...this.Messages];

							const assistantMessage = {

								id: messages.length.toString(),

								role: "assistant",

								status: "waiting",

								content: this.Translations.text.processing

							};

							

							this.WaitingResponse = true;

							

							await this.chatRef.nativeElement.addNewMessage(assistantMessage);

							

							this.fetchController = new AbortController();

							const data = this.SendHistoryMessages ? messages : [messages.at(-1)];			

							

							try {

								fetch(this.SendMessageHandlerUrl, {

									method: 'POST',

									headers: {

										'Content-Type': 'application/json'

									},

									body: JSON.stringify(data),

									signal: this.fetchController.signal

								})

								.then(async (response) =&gt; {

									

									if (!response.ok) {

										throw new Error(`HTTP error! Status: ${response.status}`);

									}

									

									await this.#sendChatHandlerResponse(assistantMessage, response);

									

									this.WaitingResponse = false;

									

									if (assistantMessage.role === 'error' &amp;&amp; this.ResponseError) {

										this.ResponseError();

									} else if (this.ResponseCompleted) {

										this.ResponseCompleted();

									}

								})

								.catch(error =&gt; {

									if (error.name !== 'AbortError') {

										this.#error();

									}

								})

								.finally(() =&gt; {

									this.cdr.markForCheck();

								});

								

								if (this.MessageSent) {

									this.MessageSent();

								}

							} catch {

								this.#error();

							} finally {

								this.cdr.markForCheck();

							}

						}

						

						##sendChatHandlerResponse = async (assistantMessage, response) =&gt; {

							const reader = response.body.getReader();

							const decoder = new TextDecoder();

							let responseComplete = false;

							let buffer = '';

							

							assistantMessage.content = "";

							assistantMessage.status = "streaming"

							this.chatRef.nativeElement.updateLastMessage(assistantMessage, "replace");

						

							do {

								const { done, value } = await reader.read();

								

								buffer += decoder.decode(value, { stream: true });

								

								let boundary = this.#getNextBoundary(buffer, done);

								while (buffer.length &gt; 0 &amp;&amp; boundary !== -1) {

									const chunk = buffer.slice(0, boundary);

									const jsonStartIndex = chunk.indexOf('{');

									const jsonText = jsonStartIndex &gt;= 0

										? chunk.slice(jsonStartIndex)

										: null;

										

									let chatResponse = null;

									if (jsonText) {

										try {

											chatResponse = JSON.parse(jsonText);

										} catch (e) {

											chatResponse = null;

										}

									}

								

									const deltaMessage = this.#chatResponseToMessage(chatResponse);

									if (deltaMessage) {

										this.chatRef.nativeElement.updateLastMessage(

											this.#updateAssistantMessage(assistantMessage, deltaMessage),

											"replace"

										);

									}

									

									buffer = buffer.slice(boundary + 1);

									boundary = this.#getNextBoundary(buffer, done);

								}

								

								responseComplete = done;

							} while (!responseComplete);

								

							assistantMessage.status = "complete"

							this.chatRef.nativeElement.updateLastMessage(assistantMessage, "replace");

						}

		

						##getNextBoundary = (str, done) =&gt; {

							const index = str.indexOf('\n');

							return index !== -1 ? index : (done ? str.length : -1);

						}

		

						##chatResponseToMessage = (chatResponse) =&gt; {

	

							if (chatResponse &amp;&amp; 'content' in chatResponse) {

								return chatResponse;

							}

					

							if (chatResponse?.choices || chatResponse?.data) {

								const choice = chatResponse.choices?.at(0);

								const content = choice?.delta?.content || choice?.message?.content;

								const documents = chatResponse.data?.documents;

								

								return {

									content,

									sources: documents?.map(doc =&gt; {

										let page = "";

						

										if (doc.metadata["loc.pageNumber"] &amp;&amp; documents.filter(item =&gt; item.metadata.id === doc.metadata.id).length &gt; 1) {

											page = `#${doc.metadata["loc.pageNumber"]}`;

										}

									

										return {

											caption: `${doc.metadata.name}.${doc.metadata.extension}${page}`,

											url:doc.metadata.source

										};

									})

								};			

							}

						}

						

						##updateAssistantMessage = (assistant, delta) =&gt; {

							assistant.content += delta.content ?? "";

							(assistant.sources ??= []).push(...(delta.sources ?? []));

							

							if (delta.role === 'error') {

								assistant.role = 'error';

							}

							if (delta.status) {

								assistant.status = delta.status;

							}

	

							return assistant;

						}

		

						##stop = () =&gt; {

							this.fetchController.abort();

							this.WaitingResponse = false;

							this.chatRef.nativeElement.updateLastMessage(

								{

									role: "assistant",

									content: "",

									status: "complete"

								},

								this.Messages.at(-1).status === "waiting" ? "replace" : "concat"

							);

							

							if (this.ResponseStopped) {

								this.ResponseStopped();

							}

						}

						

						##error = () =&gt; {

							this.WaitingResponse = false;

							this.chatRef.nativeElement.updateLastMessage(

								{

									role: "error",

									content: this.Translations.text.error,

									status: "complete"

								},

								"replace"

							);

							

							if (this.ConnectionFailed) {

								this.ConnectionFailed();

							}

						}

							

						##createProxy = () =&gt; {

							return new Proxy(

								this.Messages,

								{

									get(target, prop, receiver) {

										const message = Reflect.get(target, prop, receiver);

										

										if (typeof prop !== "symbol" &amp;&amp; Number.isInteger(Number(prop))) {

											return {

												id: message.id ? message.id : `auto-id-${prop}`,

												role: message.role,

												content: message.role === 'assistant' &amp;&amp; message.sources ? 

													{ message: message.content, sources: message.sources }

													: message.content,

												status: message.status ? message.status : 'complete'

											}

										}

									

										return message;

									}

								}

							);

						}

					&lt;/Script&gt;

					

					&lt;Script Type="before-show" Name="init"&gt;

						this.Messages ??= [];

						this.itemsProxy = this.#createProxy();

						

						this.callbacks = {

							sendChatMessages: this.#sendChat,

							stopResponse: this.#stop

						};

						

						if (this.SendMessageHandlerObject &amp;&amp; !this.SendMessageHandlerUrl) {

							this.SendMessageHandlerUrl =

								GeneXusSDNetwork.applicationServerURL() + 

								this.SendMessageHandlerObject

									.slice(37)

									.split('.')

									.map((v, i, a) =&gt; i === a.length - 1 ? 'a' + v : v)

									.join('.');

						}

						

						this.themeModel = this.MarkdownStyle &amp;&amp; {

							name: "GeneXusUIControls.Chat.MarkdownStyle",

							url: this.MarkdownStyle.substring(37) + ".css",

							attachStyleSheet: false

						};

						this.markdownTheme = this.themeModel?.name ?? null;

						this.sendContainerLayout = {

							sendContainerBefore: ["stop-response-button"],

							sendContainerAfter: ["send-button"]

						};

					&lt;/Script&gt;

					

					&lt;Script Type="method" Name="send" Async="true"&gt;

						await this.chatRef.nativeElement.sendChatMessage({

							id: "",

							role: "user",

							status: "complete",

							content

						});

					&lt;/Script&gt;

					&lt;Script Type="method" Name="stopResponse"&gt;

						if (this.WaitingResponse) {

							this.#stop();

						}

					&lt;/Script&gt;

					

					&lt;Script Type="method" Name="addNewMessage" Async="true"&gt;

						await this.chatRef.nativeElement.addNewMessage(message);

					&lt;/Script&gt;

					&lt;Script Type="method" Name="updateLastMessage" Async="true"&gt;

						const normalizedMessage = this.#chatResponseToMessage(message);

						if (normalizedMessage) {

							if (mode === "concat") {

								await this.chatRef.nativeElement.updateLastMessage(

									this.#updateAssistantMessage(this.Messages.at(-1), normalizedMessage),

									"replace"

								);					

							} else {

								await this.chatRef.nativeElement.updateLastMessage(normalizedMessage, "replace");

							}						

						}

					&lt;/Script&gt;

				&lt;/Sources&gt;

			&lt;/Platform&gt;

			

			&lt;Platform Name="Web"&gt;

				&lt;ScreenTemplate Name="Web" /&gt;

				

				&lt;Dependencies&gt;

					&lt;Dependency Type="npm" name="@genexus/chameleon-controls-library" version="6.20.1" /&gt;

					&lt;Dependency Type="shared-module" source="chameleon/chameleon.esm.js" /&gt;

				&lt;/Dependencies&gt;

				

				&lt;Sources&gt;

					&lt;Script Type="method" Name="Send"&gt;

						this.chatRef.addNewMessage({

							id: "",

							role: "user",

							status: "complete",

							content

						}).then(() =&gt; {

							this.sendChat();

						});

					&lt;/Script&gt;

					&lt;Script Type="method" Name="StopResponse"&gt;

						if (this.chatRef.waitingResponse) {

							this.stop();

						}

					&lt;/Script&gt;

					&lt;Script Type="method" Name="AddNewMessage"&gt;

						this.chatRef.addNewMessage(message);

					&lt;/Script&gt;

					&lt;Script Type="method" Name="UpdateLastMessage"&gt;

						const normalizedMessage = this.chatResponseToMessage(message);

						if (normalizedMessage) {

							if (mode === "concat") {

								this.chatRef.updateLastMessage(

									this.updateAssistantMessage(this.Messages.at(-1), normalizedMessage),

									"replace"

								);					

							} else {

								this.chatRef.updateLastMessage(normalizedMessage, "replace");

							}						

						}

					&lt;/Script&gt;

					

					&lt;Script Type="before-show" Name="methods"&gt;

						this.sendChat = () =&gt; {

							if (this.SendMessageHandlerUrl) {

								this.sendChatHandler();

							} else {

								this.sendChatEvent();

							}

						}

						

						this.sendChatEvent = () =&gt; {

							if (this.SendMessage) {

								this.SendMessage();

							}

						}

						

						this.sendChatHandler = () =&gt; {

							const messages = [...this.Messages];

							const assistantMessage = {

								id: messages.length.toString(),

								role: "assistant",

								status: "waiting",

								content: this.Translations.text.processing

							};

							

							this.chatRef.waitingResponse = true;

							this.chatRef.sendButtonDisabled = true;

							this.chatRef.addNewMessage(assistantMessage);

							

							this.fetchController = new AbortController();

							const data = this.SendHistoryMessages ? messages : [messages.at(-1)];			

							

							try {						

								fetch(this.SendMessageHandlerUrl, {

									method: 'POST',

									headers: {

										'Content-Type': 'application/json'

									},

									body: JSON.stringify(data),

									signal: this.fetchController.signal

								})

								.then(async (response) =&gt; {

									

									if (!response.ok) {

										throw new Error(`HTTP error! Status: ${response.status}`);

									}

									

									await this.sendChatResponse(assistantMessage, response);

									

									this.chatRef.waitingResponse = false;

									this.chatRef.sendButtonDisabled = false;

									

									if (assistantMessage.role === 'error' &amp;&amp; this.ResponseError) {

										this.ResponseError();

										} else if (this.ResponseCompleted) {

										this.ResponseCompleted();

									}

								})

								.catch(error =&gt; {

									if (error.name !== 'AbortError') {

										this.error();

									}

								});

								

								if (this.MessageSent) {

									this.MessageSent();

								}

								

							} catch {

								this.error();

							}

						}

					

						this.sendChatResponse = async (assistantMessage, response) =&gt; {

							const reader = response.body.getReader();

							const decoder = new TextDecoder();

							let responseComplete = false;

							let buffer = '';

							

							assistantMessage.content = "";

							assistantMessage.status = "streaming"

							this.chatRef.updateLastMessage(assistantMessage, "replace");

						

							do {

								const { done, value } = await reader.read();

								

								buffer += decoder.decode(value, { stream: true });

								

								let boundary = this.getNextBoundary(buffer, done);

								while (buffer.length &gt; 0 &amp;&amp; boundary !== -1) {

									const chunk = buffer.slice(0, boundary);

									const jsonStartIndex = chunk.indexOf('{');

									const jsonText = jsonStartIndex &gt;= 0

										? chunk.slice(jsonStartIndex)

										: null;

										

									let chatResponse = null;

									if (jsonText) {

										try {

											chatResponse = JSON.parse(jsonText);

										} catch (e) {

											chatResponse = null;

										}

									}

								

									const deltaMessage = this.chatResponseToMessage(chatResponse);

									if (deltaMessage) {

										this.chatRef.updateLastMessage(

											this.updateAssistantMessage(assistantMessage, deltaMessage),

											"replace"

										);					

									}

									

									buffer = buffer.slice(boundary + 1);

									boundary = this.getNextBoundary(buffer, done);

								}

								

								responseComplete = done;

							} while (!responseComplete);

								

							assistantMessage.status = "complete"

							this.chatRef.updateLastMessage(assistantMessage, "replace");

						}

					

						this.getNextBoundary = (str, done) =&gt; {

							const index = str.indexOf('\n');

							return index !== -1 ? index : (done ? str.length : -1);

						}

					

						this.chatResponseToMessage = (chatResponse) =&gt; {

					

							if (chatResponse &amp;&amp; 'content' in chatResponse) {

								return chatResponse;

							}

					

							if (chatResponse?.choices || chatResponse?.data) {

								const choice = chatResponse.choices?.at(0);

								const content = choice?.delta?.content || choice?.message?.content;

								const documents = chatResponse.data?.documents;

								

								return {

									content,

									sources: documents?.map(doc =&gt; {

										let page = "";

						

										if (doc.metadata["loc.pageNumber"] &amp;&amp; documents.filter(item =&gt; item.metadata.id === doc.metadata.id).length &gt; 1) {

											page = `#${doc.metadata["loc.pageNumber"]}`;

										}

									

										return {

											caption: `${doc.metadata.name}.${doc.metadata.extension}${page}`,

											url:doc.metadata.source

										};

									})

								};			

							}

						}

					

						this.updateAssistantMessage = (assistant, delta) =&gt; {	

							assistant.content += delta.content ?? "";

							(assistant.sources ??= []).push(...(delta.sources ?? []));

							

							if (delta.role === 'error') {

								assistant.role = 'error';

							}

							if (delta.status) {

								assistant.status = delta.status;

							}

							

							return assistant;

						}

					

						this.stop = () =&gt; {

							this.fetchController.abort();

							this.chatRef.waitingResponse = false;

							this.chatRef.sendButtonDisabled = false;

							this.chatRef.updateLastMessage(

								{

									role: "assistant",

									content: "",

									status: "complete"

								},

								this.Messages.at(-1).status === "waiting" ? "replace" : "concat"

							);

							

							if (this.ResponseStopped) {

								this.ResponseStopped();

							}

						}

					

						this.error = () =&gt; {

							this.chatRef.waitingResponse = false;

							this.chatRef.sendButtonDisabled = false;

							this.chatRef.updateLastMessage(

								{

									role: "error",

									content: this.Translations.text.error,

									status: "complete"

								},

								"replace"

							);

							

							if (this.ConnectionFailed) {

								this.ConnectionFailed();

							}

						}

					&lt;/Script&gt;

					

					&lt;Script Type="after-show" Name="constructor"&gt;

						const container = document.querySelector(`#${this.ContainerName}`);

						const handlerObject = gx.fn.getHidden(`${this.ControlName.toUpperCase()}_Sendmessagehandlerobject`);

						const markdownStyle = gx.fn.getHidden(`${this.ControlName.toUpperCase()}_Markdownstyle`);

						

						if (handlerObject &amp;&amp; !this.SendMessageHandlerUrl) {

							this.SendMessageHandlerUrl = gx.absoluteurl(handlerObject);

						}

						

						this.themeRef = container.querySelector("ch-theme");

						this.chatRef = container.querySelector("ch-chat");

						

						this.themeRef.model = markdownStyle &amp;&amp; {

							name: "GeneXusUIControls.Chat.MarkdownStyle",

							url: gx.getThemeElement().href.replace(/[^/]+$/, `${markdownStyle}.css`),

							attachStyleSheet: false

						};

						

						this.chatRef.callbacks = {

							sendChatMessages: this.sendChat,

							stopResponse: this.stop

						};

						this.chatRef.waitingResponse = false;

						this.chatRef.loadingState = "all-records-loaded";

						this.chatRef.markdownTheme = this.themeRef.model?.name ?? null;

						this.chatRef.items = new Proxy(

							this.Messages,

							{

								get(target, prop, receiver) {

									const message = Reflect.get(target, prop, receiver);

									

									if (typeof prop !== "symbol" &amp;&amp; Number.isInteger(Number(prop))) {

										return {

											id: message.id ? message.id : `auto-id-${prop}`,

											role: message.role,

											content: message.role === 'assistant' &amp;&amp; message.sources ? 

												{ message: message.content, sources: message.sources }

												: message.content,

											status: message.status ? message.status : 'complete'

										}

									}

								

									return message;

								}

							}

						);

						this.chatRef.translations = this.Translations;

						this.chatRef.sendContainerLayout = {

							sendContainerBefore: ["stop-response-button"],

							sendContainerAfter: ["send-button"]

						};

						

						container.appendChild(this.chatRef);

					&lt;/Script&gt;

				&lt;/Sources&gt;

			&lt;/Platform&gt;

		&lt;/Platforms&gt;

