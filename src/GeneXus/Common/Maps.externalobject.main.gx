				NetFrameworkExternalType = 'dynamic',

				JavaExternalName = 'calculateDirections',

				JavaExternalType = 'GXXMLSerializable',

				IosExternalName = 'calculatedirections',

				AndroidExternalName = 'calculateDirections'

			]

		{

			Parameters

			{

				sourceLocation

					[

						AccessType = 'In',

						Description = 'The source location for the route',

						Type = 'GeoPoint'

					]

		

				destinationLocation

					[

						AccessType = 'In',

						Description = 'The destination location for the route',

						Type = 'GeoPoint'

					]

			}

		}

		

		CalculateDirections

			[

				Description = 'Calculates directions between the source and destination locations with additional parameters',

