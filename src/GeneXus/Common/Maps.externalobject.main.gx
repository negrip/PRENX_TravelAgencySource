		StartTracking

			[

				Description = 'Starts generating tracking information',

				IsStatic = 'True',

				AndroidExternalName = 'startTracking'

			]

		{

			Parameters

			{

				changesInterval

					[

						AccessType = 'In',

						Description = 'Minimum time in seconds to generate new tracking information'

					]

		

				distance

					[

						AccessType = 'In',

						Description = 'Minimum distance in meters to generate new tracking information'

					]

		

				action

					[

						AccessType = 'In',

						Description = 'The name of the action from the parent object to be called where there is new tracking information available',

						Type = 'Character'

					]

		

				actionTimeInterval

					[

						AccessType = 'In',

						Description = 'The minimum interval in seconds between invocations to the action. Must be greater than changesInterval.'

					]

			}

		}

		

		StartTracking

			[

				Description = 'Starts generating tracking information',

				IsStatic = 'True',

