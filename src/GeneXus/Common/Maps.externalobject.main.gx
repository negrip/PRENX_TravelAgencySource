					]

		

				destinationLocation

					[

						AccessType = 'In',

						Description = 'The destination location for the route',

						Type = 'GeoPoint'

					]

		

				transportType

					[

						AccessType = 'In',

						Description = 'The transport type to use when calculating the route',

						BasedOn = 'TransportType, GeneXus.Common'

					]

		

				requestAlternateRoutes

					[

						AccessType = 'In',

						Description = 'Whether the service will serve multiple alternative routes',

						Type = 'Boolean'

					]

			}

		}

		

		CalculateDirections

			[

				Description = 'Calculates directions between the source and destination locations with additional parameters',

