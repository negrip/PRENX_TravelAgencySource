				IsStatic = 'True',

				JavascriptExternalName = 'expandTarget'

			]

		{

			Parameters

			{

				TargetName

					[

						Type = 'Character'

					]

			}

		}

		

		CollapseTarget

			[

				IsStatic = 'True',

				JavascriptExternalName = 'collapseTarget'

			]

		{

			Parameters

			{

				TargetName

					[

						Type = 'Character'

					]

			}

		}
	#End

	#ExternalEvents
		TargetShown

			[

				JavascriptExternalName = 'gx.targetshown'

			]

		{

			Parameters

			{

				TargetName

					[

						Type = 'Character'

					]

			}

		}

		

		TargetHidden

			[

				JavascriptExternalName = 'gx.targethidden'

			]

		{

