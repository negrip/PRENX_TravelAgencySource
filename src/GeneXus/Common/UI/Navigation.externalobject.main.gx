					[

						Type = 'Character'

					]

			}

		}

		

		TargetExpanded

			[

				JavascriptExternalName = 'gx.targetexpanded'

			]

		{

			Parameters

			{

				TargetName

					[

						Type = 'Character'

					]

			}

		}

		

		TargetCollapsed

			[

				JavascriptExternalName = 'gx.targetcollapsed'

			]

		{

			Parameters

			{

				TargetName

					[

						Type = 'Character'

					]

			}

		}
	#End

	#Properties
		Name = "Navigation"

		JavascriptExternalName = "gx.pO"
