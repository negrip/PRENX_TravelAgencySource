ExternalObject Navigation
{
	#ExternalMethods
		ShowTarget

			[

				Description = 'Makes a target visible. For example, ShowTarget("Left") opens the Drawer in an app with Slide Navigation.',

				IsStatic = 'True',

				JavascriptExternalName = 'showTarget'

			]

		{

			Parameters

			{

				TargetName

					[

						Type = 'Character'

					]

			}

		}

		

		HideTarget

			[

				IsStatic = 'True',

				JavascriptExternalName = 'hideTarget'

			]

		{

			Parameters

			{

				TargetName

					[

						Type = 'Character'

					]

			}

		}

		

		ExpandTarget

