SDT SynchronizationInfo
{
		SynchronizationInfo	{

			GxAppVersion [ Description = 'Application Version', DataType = 'Character(20)' ]

			Synchronizer [ Description = 'Synchronizer', DataType = 'Character(256)' ]

		}

	#Properties
