ExternalObject Actions
{
	#ExternalMethods
		Login

			[

				Description = 'Call this action to execute the standard batch login against the OAuth server.',

				Type = 'Boolean',

				IsStatic = 'True'

			]

		{

			Parameters

			{

				User

					[

						Type = 'Character'

					]

		

				Password

					[

						Type = 'Character'

					]

			}

		}

		

		Login

			[

				Description = 'Call this action to execute the standard batch login against the OAuth server.',

				Type = 'Boolean',

				IsStatic = 'True'

			]

		{

			Parameters

			{

				User

					[

						Type = 'Character'

					]

		

				Password

					[

						Type = 'Character'

					]

		

				AdditionalParameters

					[

						Type = 'LoginExternalAdditionalParameters, GeneXus.SD'

					]

			}

		}

		

		LoginExternal

			[

				Description = 'Call this action to execute the batch login against the OAuth server for a External login type.',

				Type = 'Boolean',

				IsStatic = 'True'

			]

		{

			Parameters

			{

				Type

					[

						Type = 'Character'

					]

		

				User

					[

						Type = 'Character'

					]

		

				Password

					[

						Type = 'Character'

					]

			}

		}

		

		LoginExternal

			[

				Description = 'Call this action to execute the batch login against the OAuth server for a External login type.',

				Type = 'Boolean',

				IsStatic = 'True'

			]

		{

			Parameters

			{

				Type

					[

						Type = 'Character'

					]

		

				User

					[

						Type = 'Character'

					]

		

				Password

					[

						Type = 'Character'

					]

		

				AdditionalParameters

					[

						Type = 'LoginExternalAdditionalParameters, GeneXus.SD'

					]

			}

		}

		

		Logout

			[

				Description = 'Call this action to execute the standard logout against the OAuth server.',

				IsStatic = 'True'

			]

		

		GoHome

			[

				Description = 'Returns to the main object of the application, clearing the current call stack.',

				IsStatic = 'True'

			]

		

		ReturnTo

			[

				Description = 'Returns to the object specified in the parameter. If it is present more than once in the call stack, it will return to the most recent instance.',

				IsStatic = 'True'

			]

		{

			Parameters

			{

				ObjectName

					[

						Description = 'Object to return to.',

						BasedOn = 'ObjectName, GeneXus'

					]

			}

		}

		

		Save

			[

				Description = 'Call this action to execute the standard save in the edit form in the device.',

				IsStatic = 'True'

			]

		

		Cancel

			[

				Description = 'Call this action to execute the standard cancel in the edit form in the device.',

				IsStatic = 'True'

			]

		

		CancelTo

			[

				Description = 'Returns to the object specified in the parameter, like ReturnTo method, but with the behavior of Cancel method.',

				IsStatic = 'True'

			]

		{

			Parameters

			{

				ObjectName

					[

						Description = 'Object to return to.',

						BasedOn = 'ObjectName, GeneXus'

					]

			}

		}

		

		Delete

			[

				Description = 'Call this action to execute the standard delete in the edit form in the device.',

				IsStatic = 'True'

			]

		

		TakeApplicationScreenshot

			[

				Description = 'Takes an application screenshot for further use like sharing, save in library, etc.',

				Type = 'Image',

				IsStatic = 'True'

			]
	#End

	#Properties
		Name = "Actions"
	#End

}
