Domain Geolocation
{
	#Properties
		Name = "Geolocation"

		DataType = "Character(50)"

		Length = "50"

		MaximumLength = "50"

		RegularExpression = "^\\s*(-?([0-8]?[0-9]\\.{1}\\d+|90\\.{1}0+)\\s*,\\s*-?([0-9]{1,2}\\.{1}\\d+|1[0-7][0-9]\\.{1}\\d+|180\\.{1}0+)\\s*)?$"

		AutoCorrection = "False"

		AutoCapitalization = "None"
	#End

}
