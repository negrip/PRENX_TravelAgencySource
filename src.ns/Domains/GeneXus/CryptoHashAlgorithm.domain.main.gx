Domain CryptoHashAlgorithm
{
	#Properties
		Name = "CryptoHashAlgorithm"

		Description = "Crypto Algorithm Hash"

		DataType = "Character(40)"

		Length = "40"

		MaximumLength = "40"

		EnumValues = "MD5, MD5, MD5; SHA1, SHA1, SHA1; SHA256, SHA256, SHA256; SHA384, SHA384, SHA384; SHA512, SHA512, SHA512; HMACMD5, HMAC MD5, HMACMD5; HMACSHA1, HMAC SHA1, HMACSHA1; HMACSHA256, HMAC SHA256, HMACSHA256; HMACSHA384, HMAC SHA384, HMACSHA384; HMACSHA512, HMAC SHA512, HMACSHA512"
	#End

}
