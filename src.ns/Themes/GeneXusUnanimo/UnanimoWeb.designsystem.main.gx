DesignSystem UnanimoWeb
{
	#DesignTokens
		tokens UnanimoWeb (color-scheme:dark|[light])
		{   
		    @color-scheme = light {
		        //COLORS 
		        #colors {
		            surface-transp: #ffffff7f;
		        }
		        //OPACITY
		        #opacity {
		            mask-opacity: $opacity.s;
		        }
		    }
		    @color-scheme = dark {
		        //COLORS 
		        #colors {
		            surface-transp: #1212127f;
		        }
		        //OPACITY
		         #opacity {
		            mask-opacity: $opacity.l;
		        }
		    }
		    //SPACING
		    #spacing { 
		        //TYPOGRAPHY -> Line height
		        line-height-xs: 1.14em;
		        line-height-s: 1.3em;
		        line-height-m: 1.4em;
		        line-height-l: 1.5em;
		    }
		}
	#End

	#DesignStyles
		styles UnanimoWeb
		{   
		    @import GeneXusUnanimo.Unanimo;
		    @import GeneXusUnanimo.UnanimoControls;
		
		    #region General
		        //hide submit button in iPhone/iPad 
		        input [title="submit"] [disabled] {
		            -webkit-appearance: none;
		        }
		        html, body {
		            background-color: $colors.un-surface--alternative !important; 
		            margin: 0px;
		            font-family: $fonts.un-font__family,Helvetica,Arial,sans-serif;
		            font-size: $fontSizes.un-s;
		            line-height: 1.42857143; //bootstrap-based value
		            height: 100%;
		            scrollbar-width: thin;
		            scrollbar-color: $colors.un-accent__secondary--active $colors.un-color__gray--300; 
		        }
		        .MainContainer {
		            padding-inline-end: 15px;
		            padding-inline-start: 15px;
		            margin-inline-end: auto;
		            margin-inline-start: auto;
		        }
		        .gx-ajax-error {
		            width: calc(100% - 4px);
		            background-color: $colors.un-color__red--100;
		            border-inline-start: solid 4px;
		            border-inline-start-color: $colors.un-border-color__error;
		            display: flex;
		            justify-content: space-between;
		            flex-direction: row-reverse;
		            padding: 0px;
		            margin: 0px;
		        }
		        .gx-ajax-error button {
		            margin-inline-end: 16px;
		            border: none;
		            background-color: transparent;
		            font-size: $fontSizes.un-xl;
		        }
		        .gx-ajax-error button:hover {
		            cursor: pointer;
		        }
		        .gx-ajax-error span {
		            margin-inline-start: 16px;
		        }
		        div.gx-mask {
		            position: absolute;
		            background-color: black;
		            top: 0;
		            left: 0;
		            width: 100%;
		            height: 100%;
		            animation: entermask 1s;
		            -webkit-animation: entermask 1s;
		            opacity: $opacity.mask-opacity;
		        }
		        body.gx-masked div.gx-mask {
		            position: fixed;
		            bottom: 0px;
		        }
		
		        body[dir="rtl"] div[data-align="right"] > div[data-align-outer]{
		            width: inherit;
		        }
		
		        @media screen and (max-width: 767px) {
		            .table-responsive {
		                border:none;
		            }
		        }
		    #endregion
		    
		    #region Buttons
		        //Styling input buttons for iPad and iPhone
		        input[type=button] {
		            -webkit-appearance: none;
		            -moz-appearance: none;
		            appearance: none;
		        }
		        //BUTTON PRIMARY
		        .Button.Primary {
		            @include button-primary;
		            gx-button-hovered-class: button-primary--hover;
		            gx-button-focused-class: button-primary--focused;
		            gx-button-highlighted-class: button-primary--active;
		            gx-button-disabled-class: button-primary--disabled;
		        }
		        
		        //BUTTON SECONDARY
		        .Button.Secondary {
		            @include button-secondary;
		            gx-button-hovered-class: button-secondary--hover;
		            gx-button-focused-class: button-secondary--focused;
		            gx-button-highlighted-class: button-secondary--active;
		            gx-button-disabled-class: button-secondary--disabled;
		        }
		        
		        //BUTTON TERTIARY (OUTLINED)
		        .Button.Tertiary {
		            @include button-tertiary;
		            gx-button-hovered-class: button-tertiary--hover;
		            gx-button-focused-class: button-tertiary--focused;
		            gx-button-highlighted-class: button-tertiary--active;
		            gx-button-disabled-class: button-tertiary--disabled;
		        }
		       
		        //BUTTON ROUNDED
		        .Button.Rounded {
		            @include button-rounded;
		            gx-button-hovered-class: button-rounded--hover;
		            gx-button-focused-class: button-rounded--focused;
		            gx-button-highlighted-class: button-rounded--active;
		            gx-button-disabled-class: button-rounded--disabled;
		        }
		    #endregion
		
		    #region Textblock
		        .text-helper-gray {
		            color: $colors.un-color__gray--500;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-xs;
		            letter-spacing: 0.2px;
		        }
		        .text-line-separator {
		            display: flex;
		            flex-direction: row;
		            font-family: $fonts.un-font__family;
		            color: $colors.un-text__on-surface--positive; 
		        }
		        .text-line-separator:before, .text-line-separator:after{
		            content: "";
		            flex: 1 1;
		            border-bottom: 1px solid $colors.un-border-color__mild;
		            margin: auto;
		        }
		        .text-line-separator:before {
		            margin-inline-end: 10px;
		        }
		        .text-line-separator:after {
		            margin-inline-start: 10px;
		        }
		        .TextBlock, .Textblock {
		            color: $colors.un-text__on-surface--positive;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            gx-text-block-link-class: link-enabled;
		            gx-text-block-visited-class: attribute-link--visited;
		        }
		        .TextblockExtraSmall {
		            color: $colors.un-text__on-surface--positive;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-xs;
		        }
		        .TextblockMedium {
		            color: $colors.un-text__on-surface--positive;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-l;
		        }
		        .TextblockLarge {
		            color: $colors.un-text__on-surface--positive;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-xl;
		        }
		        @media screen and (max-width: 767px) {
		            .heading-01 {
		                font-size: $fontSizes.un-xl;
		            }
		        }
		    #endregion
		
		    #region Title
		        .Title {
		            font-size: $fontSizes.un-xxl;
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--bold;
		            display: inline-block;
		            color: $colors.un-text__on-surface--positive;
		        }
		        .Subtitle {
		            @include Title;
		            letter-spacing: 0.40px;
		            font-size: $fontSizes.un-xl;
		        }
		        @media screen and (max-width: 767px) {
		            .Subtitle {
		                font-size: $fontSizes.un-xl;
		            }
		        }
		    #endregion
		
		    #region Image
		        .Image-20 {
		            width: 20px;
		        }
		        .Image-25 {
		            width: 25px;
		        }
		        .Icon-white-20{
		            width:20px;
		            filter: invert(98%) sepia(7%) saturate(4%) hue-rotate(33deg) brightness(105%) contrast(100%);
		        }
		        //Utility classes for changing svg color:
		        .color-primary {
		            filter: invert(40%) sepia(98%) saturate(2479%) hue-rotate(222deg) brightness(100%) contrast(90%);
		        }
		        @media screen and (max-width: 767px) {
		            .Image {
		                max-width: 100%;
		            }
		        }
		    #endregion
		
		    #region Action Group
		        //responsive navbar
		        .navbar {
		            border: none;
		            padding: 0px;
		        }
		        .navbar-toggle {
		            width: 28px;
		            height: 28px;
		            position: relative;
		            background-color: transparent;
		            background-image: gx-image(GeneXusUnanimo.show_more);
		            background-position: center;
		            border: none;
		            border-radius: $radius.un-radius--s;
		        }
		        .navbar-toggle:hover {
		            cursor: pointer;
		            background-color: $colors.un-accent__primary-dim--hover;
		        }
		        .navbar-brand {
		            padding-top: 7px;
		            height: auto;
		        }
		        .navbar-nav {
		            display: flex;
		            gap: $spacing.un-l;
		            flex-direction: row;
		        }
		        .navbar-nav > li { 
		            margin: 0px;
		        }
		        .navbar-default .navbar-nav>li>a:hover {
		            background-color: $colors.un-accent__primary-dim--hover;
		        }
		        .navbar-default .navbar-nav>.open>a {
		            background-color: $colors.un-accent__primary-dim--hover;
		        }
		        .gx-action-group {
		            display: flex;
		            gap: $spacing.un-l;
		        }
		        .ww__actions-cell .ActionGroup .Button {
		            display: block;
		            font-size: $fontSizes.un-s;
		            letter-spacing: 0.25px;
		            text-align: start;
		            width: 100%;
		        }
		        //Menu Action Group
		        .MenuOption {
		            color: $colors.un-text__on-secondary;
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--bold;
		            font-size: $fontSizes.un-s;
		            font-weight: bold;
		            letter-spacing: 0.38px;
		            line-height: 13px;
		            text-align: center;
		            text-transform: uppercase;
		            text-decoration: none;
		            padding: 8px 13px 8px 13px;
		        }
		        .gx-dropdown-menu .MenuOption {
		            display: block;
		            color: $colors.un-text__on-secondary;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            font-weight: normal;
		            letter-spacing: 0.25px;
		            line-height: 16px;
		            text-transform: none;
		            text-align: start;
		        }
		        a.MenuOption:hover {
		            background-color: $colors.un-accent__secondary--active !important;
		        }
		        .dropdown .MenuOption:hover {
		            background-color: $colors.un-accent__secondary;
		        }
		        .dropdown-toggle {
		            @include MenuOption;
		        }
		        .dropdown-toggle:hover {
		            background-color: $colors.un-accent__secondary--active;
		        }
		        .dropdown-toggle .caret {
		           display: inline-block;
		           border-top: 4px dashed $colors.un-border-color__primary;
		           border-inline-start: 4px solid transparent;
		           border-inline-end: 4px solid transparent;
		           margin-inline-start: 4px; 
		           vertical-align: middle;
		        }
		        //horizontal divider
		        .HorizontalLine {
		            display: block;
		            height: 1px;
		            margin: 0px 8px;
		            background-color: $colors.un-accent__secondary--active;
		        }
		        .dropdown-menu {
		            margin-top: 7px;
		            background-color: $colors.un-accent__secondary;
		            border-radius: $radius.un-radius--l;
		            box-shadow: 0px 3px 4px 0px rgba(0, 0, 0, 0.14),
		            0px 3px 3px -2px rgba(0, 0, 0, 0.12),
		            0px 1px 8px 0px rgba(0, 0, 0, 0.2);
		            padding: 0px;
		            padding-bottom: 3px;
		        }
		        .navbar-nav .dropdown {
		            position: unset;
		        }
		        li.dropdown  {
		            padding-top: 0px;
		        }
		        .dropdown-menu > li {
		            margin: 0px;
		        }
		        //hide navbar-header if no caption
		        .navbar-header span.navbar-brand:empty {
		            display: none;
		        }
		        //center navbar items if there are placed on Header
		        .HeaderContainer nav.ActionGroup {
		            text-align: center;
		        }
		        .HeaderContainer .gx-navbar {
		            padding-top: 6px;
		        }
		        li:empty { 
		            display: none;
		        }
		        ul.nav {
		            padding-inline-start: 0px;
		        }
		        
		        div.ActionGroup:first-child {
		            border-top-left-radius: 5px;
		            border-bottom-left-radius: 5px;
		        }
		        .nav:before, .nav:after {
		            content: none;
		        }
		        //using Unanimo buttons style
		        .action-group .navbar-text { 
		            color: $colors.un-text__primary;
		            display: block;
		        }
		        .action-group .dropdown-toggle {
		            @include action-group-option;
		            color: $colors.un-text__primary;
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--semibold;
		            height: 28px;
		            line-height: 10px;
		        }
		        .action-group .dropdown-menu {
		            margin-top: 1px;
		        }
		        .action-group-option { 
		            @include button-tertiary; 
		            text-decoration: none;
		            min-height: 28px;
		            line-height: 26px;
		            min-width: 80px;
		            padding-inline-start: $spacing.un-l;
		            padding-inline-end: $spacing.un-l;
		            border-radius: $radius.un-radius--s;
		            text-align: center;
		            white-space: nowrap;
		        }
		        .action-group-option a {
		            text-decoration: none;
		            color: $colors.un-text__primary;
		        }
		        .action-group-option-img {
		            background-image: gx-image(GeneXusUnanimo.show_more);
		        }
		        .action-group .dropdown-toggle {
		            border: solid 1px $colors.un-border-color__primary;
		            border-radius: $radius.un-radius--s;
		        }
		        .gx-dropdown-menu .action-group-option {
		            display: block;
		            color: $colors.un-text__on-surface--positive;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            font-weight: normal;
		            letter-spacing: 0.25px;
		            text-transform: none;
		            text-align: start;
		            height: 28px;
		            line-height: 28px;
		            border: none;
		        }
		        .gx-dropdown-menu a.action-group-option:hover {
		            background-color: $colors.un-accent__primary-dim--hover;
		        }
		        .gx-dropdown-menu .Button {
		            display: block;
		            color: $colors.un-text__on-surface--positive;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            font-weight: normal;
		            letter-spacing: 0.25px;
		            text-transform: none;
		            text-align: start;
		            height: 28px;
		            line-height: 28px;
		            border: none;
		            width: 100%;
		        }
		        .Submenu {
		            background-color: $colors.un-surface--positive;
		            width: max-content;
		        }
		        .dropdown-toggle .TextBlock {
		            color: $colors.un-text__primary;
		        }
		        ul.action-group-option {
		            background-color: $colors.un-surface--positive;
		            padding: 0px;
		            padding-bottom: 3px;
		            border: none;
		            border-radius: $radius.un-radius--l;
		        }
		        ul.action-group-option:hover {
		            background-color: $colors.un-surface--positive;
		        }
		
		        @media screen and (max-width: 767px) {
		            .navbar-collapse[aria-expanded="true"]{ 
		                display: flex;
		                flex-direction: column;
		            }
		            .dropdown-menu {
		                box-shadow: none;
		            }
		            .gx-action-group {
		                margin-bottom: $spacing.un-l;
		            }
		            .ww__actions-container .gx-action-group {
		                margin-bottom: 0;
		            }
		            .navbar-nav {
		                display: contents;
		            } 
		            .action-group .navbar-collapse .action-group-option {
		                border: none;
		            }
		            .action-group .navbar-collapse .dropdown-toggle {
		                border: none;
		            }
		            .action-group .navbar-collapse {
		                padding-block: $spacing.un-s;
		                background-color: $colors.un-surface--positive;
		                border-radius: $radius.un-radius--l;
		                box-shadow: $shadows.xs;
		                position: absolute;
		                z-index: 1;
		            }
		            .dropdown-toggle .caret {
		                border-top: 4px solid transparent;
		                border-bottom: 4px solid transparent;
		                border-inline-start: 4px dashed $colors.un-border-color__primary;
		                margin-inline-start: 6px;
		                transform: rotate(90deg);
		            }
		            div[data-align="right"] .gx-navbar .navbar-collapse {
		                inset-inline-end: 16px;
		            }
		            .ww__actions-container .navbar-collapse {
		                padding-block: $spacing.un-s;
		                margin-bottom: $spacing.un-m;
		                background-color: $colors.un-surface--positive;
		                border-radius: $radius.un-radius--l;
		                box-shadow: $shadows.xs;
		                position: absolute;
		                z-index: 1;
		            }
		            .ww__actions-container .navbar-collapse li input {
		                background-color: $colors.un-surface--positive;
		                color: $colors.un-text__primary;
		                border: none;
		            }
		            .ww__actions-container .navbar-collapse li input:hover {
		                background-color: $colors.un-accent__primary-dim--hover;
		            }
		            .ww__actions-container .Submenu li input {
		                color: $colors.un-text__on-surface--positive;
		            }
		            .ww__actions-cell .ActionGroup .navbar-header {
		                display: block;
		            }
		            .dropdown .dropdown-menu {
		                box-shadow: $shadows.s;
		                position: fixed;
		                inset-inline-start: 100px;
		            } 
		            div[data-align="right"] .dropdown .dropdown-menu {
		                inset-inline-start: unset;
		                inset-inline-end: 100px;
		            }
		            div[data-align="center"] .dropdown .dropdown-menu {
		                inset-inline-start: unset;
		                inset-inline-end: unset;
		            }
		            .navbar-collapse .dropdown-toggle {
		                text-align: left;
		                padding-inline: 16px;
		            }
		        }
		        @media screen and (min-width: 768px) {
		            .dropdown:hover>.dropdown-menu {
		                //display: block;
		            }
		            .navbar-toggle {
		                display: none;
		            }
		            .action-group .container-fluid {
		                padding: 0px;
		            }
		        }
		         
		    #endregion
		
		    #region Containers
		        #region Group
		            .Group {
		                padding: 0px;
		                border: 0px;
		                margin: 0px;
		                min-width: 0px;
		            }
		            .GroupTitle {
		                color: $colors.un-text__on-surface--positive;
		                font-family: $fonts.un-font__family;
		                font-weight: $fonts.un-font__weight--bold;
		                font-size: $fontSizes.un-l;
		                letter-spacing: $spacing.letter-spacing-s;
		                width: 100%;
		                height: 30px;
		                padding: 0;
		                margin-bottom: $spacing.un-l;
		                border: 0;
		                border-bottom: 1px solid $colors.un-border-color__mild;
		            }
		            //Group content
		            .Group > div {
		                padding-inline-start: $spacing.un-l;
		            }
		        #endregion
		
		        #region Flex
		            .Flex {
		                column-gap: $spacing.un-l;
		            }
		            .actions-container {
		                flex-wrap: wrap;
		            }
		
		            @media screen and (max-width: 767px) {
		                .actions-container :nth-child(1){
		                    //order: -1;
		                    flex: 0 0 100%;
		                }
		            }
		        #endregion
		    #endregion
		
		    #region GX Messages
		        .gx-warning-message, .gx-error-message, .gx-success-message {
		            font-size: $fontSizes.un-s;
		            margin-block: $spacing.un-m;
		            display: block;
		            padding-inline-start: 22px;
		        }
		        .ErrorMessages:before,
		        .gx-warning-message:before,
		        .gx-success-message:before {
		            content: "";
		            width: 20px;
		            height: 20px;
		            position: absolute;
		            background-repeat: no-repeat;
		            background-position: center center;
		            background-size: 100%;
		        }
		        .ErrorMessages:before {
		            inset-inline-start: $spacing.un-s;
		            background-image: gx-image(GeneXusUnanimo.error_ico);
		        }
		        .ErrorMessages, .gx-error-message, 
		        .WarningMessages, .gx-warning-message,
		        .gx-success-message {
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--semibold;
		            position: relative;
		        }
		        .ErrorMessages {
		            color: $colors.un-text__error;
		            margin-inline-start: 28px;
		        }
		        .ErrorViewer {
		            color: $colors.un-text__error;
		        }
		        .gx-error-message {
		            background-image: gx-image(GeneXusUnanimo.error_ico);
		            background-repeat: no-repeat;
		            background-position: left;
		            padding-inline-start: 25px;
		        }
		        //Warning
		        .WarningMessages {
		            color: $colors.un-text__warning;
		            background-image: gx-image(GeneXusUnanimo.warning_ico);
		            background-repeat: no-repeat;
		            background-position-y: center;
		            padding-inline-start: 28px;
		        }
		        .gx-warning-message:before {
		            background-image: gx-image(GeneXusUnanimo.warning_ico);
		            inset-inline-start: 0px;
		        }
		        .gx-warning-message {
		            color: $colors.un-text__warning;
		        }
		        //Error
		        .gx-error-message:before {
		            background-image: gx-image(GeneXusUnanimo.error_ico);
		            inset-inline-start: -22px;
		        }
		        .gx-error-message {
		            color: $colors.un-text__error;
		        }
		        //Success
		         .gx-success-message:before {
		            background-image: gx-image(GeneXusUnanimo.success_ico_green);
		            inset-inline-start: 0px;
		        }
		        .gx-success-message {
		            color: $colors.un-text__success;
		        }
		    #endregion
		    
		    #region Recent Links Container
		        .RecentLinksMainTable {
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		        }
		        .RecentLinksContainer {
		            background-color: $colors.un-surface--positive;
		            min-height: 40px;
		            font-size: $fontSizes.un-s;
		            display:flex;
		            align-items: center;
		            margin: 0 -15px;
		            margin-bottom: $spacing.un-xxl;    
		        }
		        .RecentLinksContainer > .row {
		            width: 100%;
		        }
		        .RecentsTitle {
		            gx-text-block-link-class: link-enabled;
		        }
		        .RecentLinkItem {
		            color: $colors.un-text__disabled;
		            gx-text-block-link-class: link-enabled;
		            gx-text-block-highlighted-class: link-focus;
		            margin-inline-end: $spacing.un-l;
		        }
		        .RecentLinkItem:focus {
		            outline: none;
		        }
		        .RecentLinkItem:active {
		            outline: none;
		        }
		        .RecentLinkItem:after {
		            content: "/";
		            position: relative;
		            inset-inline-start: $spacing.un-m;
		        }
		        .RecentLinksGrid > .row > div:last-child .RecentLinkItem:after{
		            display: none;
		        }
		        .RecentLinksGrid > .row > div {
		            padding-block: 0px;
		            padding-inline: 0px;
		            width: auto;
		        }
		        @media screen and (max-width: 767px) {
		            .RecentLinksMainTable {
		                overflow: hidden;
		                max-height: 25px;
		                padding: 5px;
		                -moz-transition: max-height 0.5s ease-in-out;
		                -webkit-transition: max-height 0.5s ease-in-out;
		                -ms-transition: max-height 0.5s ease-in-out;
		                transition: max-height 0.5s ease-in-out;
		            }    
		            .RecentLinksMainTableExpanded {
		                max-height: 500px;
		            }
		            .RecentLinksGrid {
		                padding-inline-start: 15px;
		            }
		        }
		    #endregion
		    
		    #region Links
		        .link-enabled {
		            color: $colors.un-link__font-color;
		            text-decoration: underline;
		            gx-text-block-hovered-class: link-hover;
		            gx-attribute-hovered-class: link-hover;
		            gx-text-block-focused-class: link-focus;
		            gx-attribute-focused-class: link-focus;
		        }
		        .link-hover {
		            color: $colors.un-link__font-color--hover;
		        }
		        .link-focus {
		            outline-width: $borders.un-width--s;
		            outline-style: solid;
		            outline-color: $colors.un-border-color__secondary;
		            outline-offset: 3px;
		        }
		    #endregion
		    
		    #region Transaction Buttons
		        //BTN SELECT
		        .BtnSelect {
		            @include button-secondary;
		            height: 28px;
		            line-height: $spacing.line-height-l;
		            gx-button-hovered-class: button-secondary--hover;
		            gx-button-highlighted-class: button-secondary--active;
		            gx-attribute-focused-class: button-secondary--focused;
		        }
		        .ToolbarCellClass {
		            margin-bottom: $spacing.un-l;
		            width: 100%;
		            margin-inline-start: 0;
		            text-align: center;
		            display: flex;
		            justify-content: center;
		        }
		        .BtnFirst,.BtnPrevious, .BtnNext, .BtnLast {
		            @include button-secondary;
		            background-position: center center;
		            border: none;
		            gx-button-hovered-class: navigationButtonsHover;
		            gx-button-highlighted-class: navigationButtonsHighlighted;
		            gx-button-focused-class: navigationButtonsFocus;
		            padding-inline-start: $spacing.un-l;
		            padding-inline-end: $spacing.un-l;
		            height: 28px;
		        }
		        .navigationButtonsHighlighted {
		            @include button-secondary--active;
		            gx-button-focused-class: navigationButtonsHighlightedFocused;
		        }
		        .navigationButtonsHighlightedFocused {
		            outline: none;
		        }
		        .navigationButtonsFocus {
		            @include button-secondary--focused;
		        }
		        //BTN FIRST
		        .BtnFirst {
		            background-image: gx-image(GeneXusUnanimo.arrow_first);
		            gx-button-highlighted-class: BtnFirst-highlighted;
		        }
		        .BtnFirst-highlighted {
		            background-image: gx-image(GeneXusUnanimo.arrow_first);
		        }
		        //BTN PREVIOUS
		        .BtnPrevious {
		            background-image: gx-image(GeneXusUnanimo.arrow_left);
		            gx-button-highlighted-class: BtnPrevious-highlighted;
		        }
		        .BtnPrevious-highlighted {
		            background-image: gx-image(GeneXusUnanimo.arrow_left);
		        }
		        //BTN NEXT
		        .BtnNext, .BtnNext:active {
		            background-image: gx-image(GeneXusUnanimo.arrow_right);
		        }
		        //BTN LAST
		        .BtnLast {
		            background-image: gx-image(GeneXusUnanimo.arrow_last);
		            gx-button-highlighted-class: BtnLast-highlighted;
		        }
		        .BtnLast-highlighted {
		            background-image: gx-image(GeneXusUnanimo.arrow_last);
		        }    
		        .navigationButtonsHover {
		            @include button-secondary--hover;
		        }
		        //BTN CONFIRM
		        .GX_BtnEnter {
		            @include button-secondary;
		        }
		        //BTN DELETE
		        .BtnDelete {
		            @include button-tertiary;
		            height: 28px;
		            min-width: 80px;
		            border-radius: $radius.un-radius--s;
		            line-height: $spacing.line-height-l;
		            gx-button-hovered-class: button-tertiary--hover;
		            gx-button-highlighted-class: button-tertiary--active;
		            gx-attribute-focused-class: button-tertiary--focused;
		            gx-button-disabled-class: button-tertiary--disabled;
		        }
		        .button-secondary-active-focus {
		            outline: none;
		            color: $colors.un-text__primary--active;
		        }
		        //BTN CANCEL
		        .BtnCancel {
		            @include button-tertiary;
		            height: 28px;
		            min-width: 80px;
		            border-radius: $radius.un-radius--s;
		            line-height: $spacing.line-height-l;
		            margin-inline-start: $spacing.un-s;
		            margin-inline-end: $spacing.un-s;
		            gx-button-hovered-class: button-tertiary--hover;
		            gx-button-focused-class: button-tertiary--focused;
		            gx-button-highlighted-class: button-tertiary--active;
		            gx-button-disabled-class: button-tertiary--disabled;
		        }
		        //BTN ENTER
		        .BtnEnter {
		            @include button-primary;
		            height: 28px;
		            min-width: 80px;
		            border-radius: $radius.un-radius--s;
		            line-height: $spacing.line-height-l;
		            gx-button-hovered-class: button-primary--hover;
		            gx-button-focused-class: button-primary--focused;
		            gx-button-highlighted-class: button-primary--active;
		            gx-button-disabled-class: button-primary--disabled;
		        }
		        .btn-group {
		            display: flex;
		        }
		    #endregion
		    
		    #region Transaction Prompts
		        body:before{
		            content: "";
		            opacity: 0;
		            transition: opacity .5s;
		            z-index: 1;
		        }
		        .gx-popup-default {
		            gx-popup-resize-handle-class: gx-popup-resize;
		        }
		        body.gx-popup-opened:before {
		            content: "";
		            position: absolute;
		            width: 100%;
		            height: 100%;
		            background-color: black;
		            opacity: $opacity.mask-opacity;
		            z-index: 10;
		            position: fixed;
		        }
		        .gx-popup-document {
		            background-color: $colors.overlay-bg !important;
		        }
		        .gx-popup-document .title-container:first-child {
		            display: none;
		        }
		        .gx-popup-document .form__table-level {
		            border-top-color: $colors.un-surface--positive;
		        }
		        .gx-popup-resize {
		            content: gx-image(GeneXusUnanimo.resize_ico);
		        }
		        .gx-responsive-popup .gx-popup-resize {
		            inset-inline-end: 6px;
		            bottom: 6px; 
		        }
		        .gx-popup-document body, .PopupBorder {
		            background-color: $colors.overlay-bg !important; 
		        }
		        .PopupBorder {
		            background-color: $colors.overlay-bg; 
		            border-radius: $radius.un-radius--l;
		            box-shadow: $shadows.s;
		            padding-top: $spacing.un-l;
		            padding-bottom: 11px;
		        }
		        //Popup title
		        .PopupHeader {
		            display: flex;
		            justify-content: space-between;
		        }
		        .PopupHeader .PopupTitle {
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--bold;
		            color: $colors.un-text__on-surface--positive;
		            font-size: $fontSizes.un-xl;
		            margin-inline-start: $spacing.un-l;
		            display: block;
		            margin-top: $spacing.un-l;
		            margin-bottom: $spacing.un-xl;
		        }
		        .PopupHeader .PopupHeaderButton:before {
		            content: "";
		            display: block;
		            width: 24px;
		            height: 24px;
		            background-image: gx-image(GeneXusUnanimo.close_ico);
		            cursor: pointer;
		            position: relative;
		            inset-inline-end: $spacing.un-l;
		        }
		        .WWFiltersCell .Attribute {
		            margin-block: $spacing.un-s;
		        }
		        //Filter labels
		        .WWFilterLabel:focus {
		            
		        }
		        .WWFilterLabel,
		        .WWDateFilterLabel {
		            gx-text-block-link-class: WWFilterLabelLink;
		        }
		        .AdvancedContainerItem {
		            border-bottom-width: $borders.un-width--xs;
		            border-bottom-style: solid;
		            border-bottom-color: $colors.un-border-color__mild; 
		            padding-block: 9px;
		        } 
		        .AdvancedContainerVisible .row:last-child .AdvancedContainerItem {
		            border-bottom: 0;
		        }
		        //uncollapsed
		        .AdvancedContainerItem .WWFilterLabel,
		        .AdvancedContainerItem .WWDateFilterLabel {
		            display: block;
		            background-image: gx-image(GeneXusUnanimo.arrow_desc);
		            background-position: top 0px right;
		            background-repeat: no-repeat;
		            background-size: 20px;
		        }
		        body[dir="rtl"] .AdvancedContainerItem .WWFilterLabel {
		            background-position: top 3px left;
		        }
		        body[dir="rtl"] .AdvancedContainerItem .WWDateFilterLabel {
		            background-position: top 3px left;
		        }
		        //collapsed
		        .AdvancedContainerItemExpanded .WWFilterLabel,
		        .AdvancedContainerItemExpanded .WWDateFilterLabel {
		            background-image: gx-image(GeneXusUnanimo.arrow_asc);
		        }
		        .WWFilterLabel, .WWDateFilterLabel {
		            @include filter-item__label;
		            display: block !important;
		            position: relative;
		        }
		        .WWFilterLabelLink {
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__disabled;
		            text-decoration: none;
		            font-family: $fonts.un-font__family;
		        }
		        .AdvancedContainerItem {
		            border-bottom-style:solid;
		            border-bottom-width: $borders.un-width--xs;
		            border-bottom-color: $colors.un-border-color__mild;
		            padding-block: 10px;
		        }
		        .TableRowHovered {
		            background-color: $colors.row-hover;
		        }
		        .ReadonlyAttribute a {
		            color: $colors.un-text__primary; 
		            text-decoration: underline;
		        }
		        .ReadonlyAttribute a:hover {
		            color: $colors.un-text__primary--hover;
		        }
		        .ReadonlyDownloadAttribute {
		            width: 64px;
		        }
		        .DescriptionAttribute a{
		            color: $colors.un-text__primary; 
		            text-decoration: underline;
		        }
		        .DescriptionAttribute a:hover {
		            color: $colors.un-text__primary--hover;
		        }
		        //PAGINATION BUTTONS
		        .PagingButtonsFirst,
		        .PagingButtonsPrevious,
		        .PagingButtonsNext,
		        .PagingButtonsLast
		        {
		            background-color: transparent;
		            background-repeat: no-repeat;
		            background-size: 23px;
		            height: 32px;
		            width: 32px;
		            display: inline-block;
		            padding: 0;
		            background-position: center center;
		            border: none;
		            border-radius: 0;
		            cursor: pointer;
		            gx-button-hovered-class: button-secondary--hover;
		            gx-button-disabled-class: PagingButtonsDisabled;
		        }
		        .PagingButtonsDisabled {
		            opacity: .5 !important;
		        }
		        
		        //Page Button First
		        .PagingButtonsFirst {
		            background-image: gx-image(GeneXusUnanimo.arrow_first);
		            gx-button-highlighted-class: PagingButtonsFirst-highlighted;
		            gx-button-focused-class: PagingButtonsFirst-focus;
		        }
		        .PagingButtonsFirst-highlighted {
		            @include button-secondary--active;
		            background-image: gx-image(GeneXusUnanimo.arrow_first);
		        }
		        .PagingButtonsFirst-focus {
		            @include button-secondary--focused;
		            gx-button-highlighted-class: button-secondary--focused;
		        }
		        //Page Button Previous
		        .PagingButtonsPrevious {
		            background-image: gx-image(GeneXusUnanimo.arrow_left);
		            gx-button-highlighted-class: PagingButtonsPrevious-highlighted;
		            gx-button-focused-class: PagingButtonsPrevious-focus;
		        }
		        .PagingButtonsPrevious-highlighted {
		            @include button-secondary--active;
		            background-image: gx-image(GeneXusUnanimo.arrow_left);
		        }
		        .PagingButtonsPrevious-focus {
		            @include button-secondary--focused;
		            gx-button-highlighted-class: button-secondary-focused-highlighted;
		        }
		        //Page Button Next
		        .PagingButtonsNext {
		            background-image: gx-image(GeneXusUnanimo.arrow_right);
		            gx-button-highlighted-class: PagingButtonsNext-highlighted;
		            gx-button-focused-class: PagingButtonsNext-focus;
		        }
		        .PagingButtonsNext-highlighted {
		            @include button-secondary--active;
		            background-image: gx-image(GeneXusUnanimo.arrow_right);
		        }
		        .PagingButtonsNext-focus {
		            @include button-secondary--focused;
		            gx-button-highlighted-class: button-secondary--focused;
		        }
		        //Page Button Last
		        .PagingButtonsLast {
		            background-image: gx-image(GeneXusUnanimo.arrow_last);
		            gx-button-highlighted-class: PagingButtonsLast-highlighted;
		            gx-button-focused-class: PagingButtonsLast-focus;
		        }
		        .PagingButtonsLast-highlighted {
		            @include button-secondary--active;
		            background-image: gx-image(GeneXusUnanimo.arrow_last);
		        }
		        .PagingButtonsLast-focus {
		            @include button-secondary--focused;
		            gx-button-highlighted-class: button-secondary--focused;
		        }
		        body[dir="rtl"] [class*='PagingButtons'] {
		            transform: rotate(180deg);
		        }
		        //Paging footer
		        .gx-grid-paging-bar {
		            display: flex;
		            justify-content: flex-end;
		            padding-block: 5px;
		        }
		        //Btn cancel Prompt
		        .PromptContainer .BtnCancel  {
		            margin-inline-start: 0;
		        }
		        .PromptContainer .WWGridCell {
		            margin-inline-start: 0px;
		            width: 75%;
		            height: 100vh;
		            padding-inline-start: 15px; 
		            padding-inline-end: 15px;
		        }
		        .PromptContainer .WWGridCell > .Table {
		            height: 100vh;
		            display: flex;
		            flex-direction: column;
		        }
		        .PromptContainer .WWGridCell > .Table > .row:nth-child(2) {
		            flex-grow: 1;
		        }
		        .PromptContainer .WWGridCell > .Table > .row:nth-child(3) {
		            align-self: flex-end;
		        }
		        @media screen and (max-width: 767px) {
		            .PromptContainer .WWGridCell {
		                width: 100%;
		            }
		            .gx-responsive-popup.gx-popup {
		                width: 90vw;
		                top: 5vh;
		                inset-inline-start: 5vw;
		                min-height: 80vh;
		            }
		            .gx-responsive-popup .gx-popup-content {
		                width: 100%;
		            }
		            .gx-responsive-popup .gx-popup-content > iframe {
		                width: 90vw !important;
		                min-height: 80vh;
		            }
		            .PromptMainTable {
		                width: 90vw;
		                margin: 0px;
		            }
		            .PromptMainTable .PromptContainer{
		                padding: 0px;
		            }
		        }
		    #endregion
		    
		    #region Form Container
		        .TabsFormContainer {
		            padding-inline-start: $spacing.un-xxl;
		            padding-inline-end: $spacing.un-xxl;
		        }
		        .FiltersContainer {
		            display: none;
		            background-color: $colors.un-surface--positive;
		            padding: $spacing.un-l;
		            border: solid $borders.un-width--xs;
		            box-shadow: $shadows.m;
		        }
		        .FiltersContainerVisible {
		            display: inherit;
		        }
		        .TableTop {
		            margin-bottom: $spacing.un-l;
		        }
		        //expandible container
		        .expandible-container {
		            margin-inline-start: 257px;
		            width: calc(100% - 274px);
		            transition: margin-inline-start .3s, width .2s ease-out;
		        }
		        .expanded {
		            margin-inline-start: 57px;
		            width: calc(100% - 74px);
		            transition: margin-inline-start .3s, width .2s ease-out;
		        }
		        .table-login {
		            width: 360px;
		            padding: 45px 50px 45px 50px;
		            background-color: $colors.un-surface--positive;
		            border-radius: $radius.un-radius--l;
		            box-shadow: $shadows.xxs;
		        }
		
		        @media screen and (max-width: 767px) {
		            .TabsFormContainer {
		                padding-inline-start: $spacing.un-l;
		                padding-inline-end: $spacing.un-l ;
		            }
		            //hidden in xs
		            .hidden-xs {
		                display: none !important; 
		            }
		            .table-login {
		                width: 100%;
		            }
		            .expandible-container {
		                margin-inline-start: 0px;
		                width: 100%; 
		            }
		        }
		
		        @media (min-width: 768px) and (max-width: 991px) {
		            .hidden-sm {
		                display: none !important;
		            }
		        }
		        @media (min-width: 992px) and (max-width: 1199px) {
		            .hidden-md {
		                display: none !important;
		            }
		        }
		        @media (min-width: 1200px) {
		            .hidden-lg {
		                display: none !important;
		            }
		        }
		    #endregion
		    
		    #region Attribute
		        .Attribute {
		            min-height: 28px;
		            max-width: 100%;
		            font-family: $fonts.un-font__family;//$fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            padding-inline-start: $spacing.un-m;
		            padding-inline-end: $spacing.un-m;
		            border-color: $colors.un-border-color__strong;
		            color: $colors.un-text__on-surface--positive;
		            background-color: $colors.attribute-bg;
		            border-radius: $radius.un-radius--m;
		            gx-attribute-focused-class: AttributeFocusedClass;
		            gx-readonly-class: ROAttribute;
		            gx-label-class: attribute-label;
		            gx-datepicker-image-class: datepicker-image;
		            gx-prompt-image-class: gx-prompt;
		        }
		        // WW pattern compatible
		        .ReadonlyAttribute {
		            @include Attribute;
		            padding-inline-start: 0px;
		            padding-inline-end: 0px;
		            color: $colors.un-text__on-surface--positive;
		            background-color: transparent;
		        }
		        .ROAttributeSearch { 
		            @include AttributeSearch;
		            color: $colors.un-text__on-surface--positive;
		        }
		        //description attribute
		        .attribute-description {
		            gx-attribute-link-class: attribute-link;
		            gx-attribute-visited-class: attribute-link--visited;
		            gx-attribute-hovered-class: attribute-link--hover;
		        }
		        .attribute-link {
		            color: $colors.un-text__primary; 
		            text-decoration: underline;
		        }
		        .attribute-link--visited {
		            @include attribute-link;
		            color: $colors.un-link__font-color--active; 
		        }
		        .attribute-link--hover {
		            @include attribute-link;
		            color: $colors.un-link__font-color--hover; 
		        }
		        .form-control {
		            display: block;
		            border-width: 1px;
		            border-style: solid;
		        }
		        .form-group {
		            margin-bottom: 15px;
		        }
		        .form-horizontal .form-group:after {
		            display: table;
		            content: " ";
		            clear: both;
		        }
		        .form-horizontal .form-group {
		            margin-inline-start: -15px;
		            margin-inline-end: -15px;
		        }
		        .input-group {
		            position: relative;
		            display: table;
		        }
		        .input-group .form-control {
		            position: relative;
		            z-index: 1;
		            float: left;
		        }
		        input.Attribute:disabled ~ .input-group-btn {
		            display: none;
		        }
		        body[dir="rtl"] .input-group .form-control {
		            float: right;
		        }
		        .dp_container > .input-group {
		            display: flex;
		            align-items: center;
		            flex-wrap: nowrap;
		        }
		        //error attribute
		        .ErrorAttribute {
		            @include Attribute;
		            height: 28px;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		            border-radius: $radius.un-radius--m;
		            border-color: $colors.un-border-color__error;
		        }
		        .Attribute.ErrorAttribute {
		            border-color: $colors.un-border-color__error;
		            gx-attribute-focused-class: Attribute-ErrorAttribute-focused;
		        }
		        .Attribute-ErrorAttribute-focused {
		            border-color: $colors.un-border-color__error;
		            box-shadow: 0px 0px 0px 1px #f02031;
		        }
		        .AttSubTitle {
		            Label: attribute-label;
		            width: auto !important;
		            gx-attribute-focused-class: AttributeFocusedClass;
		        }
		        .AttSubTitle.Errorform-control {
		            border-color: $colors.un-border-color__error;
		            gx-attribute-focused-class: AttSubTitle-Errorform-control-focused;
		        }
		        .AttSubTitle-Errorform-control-focused {
		            border-color: $colors.un-border-color__error;
		            box-shadow: 0px 0px 0px 1px #f02031;
		        }
		        //warning attribute
		        .WarningAttribute {
		            @include Attribute;
		            height: 28px;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		            border-radius: $radius.un-radius--m;
		            border-color: $colors.un-border-color__warning;
		        }
		        .AttributeFocusedClass {
		            border-color: $colors.un-border-color__secondary;
		            box-shadow: 0px 0px 0px 1px #13142c;
		        }
		        //Image on Trn form
		        .ImageAttributeLabel {
		            @include attribute-label;
		        }
		        //Blobfile on Trn form
		        .DownloadAttributeLabel {
		            @include attribute-label;
		        }
		        .ReadonlyDownloadAttributeLabel {
		            @include attribute-label;
		        }
		        //Audio on Trn form
		        .AudioAttributeLabel {
		            @include attribute-label;
		        }
		        //Video on Trn form
		        .VideoAttributeLabel {
		            @include attribute-label;
		        }
		        //show password on input = password
		        .input-group input[data-gx-password-reveal] {
		            width: auto; 
		        }
		        .gx-pwd-reveal-btn {
		            position: absolute;
		            z-index: 2;
		            inset-inline-end: 0;
		            top: 0;
		        }
		        .gx-pwd-reveal-btn .btn {
		            border: none;
		            background-color: transparent;
		        }
		        .gx-pwd-reveal-btn .btn:hover {
		            background-color: transparent !important;
		        }
		        .gx-pwd-reveal-btn .glyphicon-eye-open {
		            width: 28px;
		            height: 28px;
		            background-image: gx-image(GeneXusUnanimo.password_show);
		            background-size: 20px; 
		            background-repeat: no-repeat;
		            background-position: center;
		            cursor: pointer;
		        }
		        .gx-pwd-reveal-btn .glyphicon-eye-close {
		            width: 28px;
		            height: 28px;
		            background-image: gx-image(GeneXusUnanimo.password_hidden);
		            background-size: 20px; 
		            background-repeat: no-repeat;
		            background-position: center;
		            cursor: pointer;
		        }
		        //Image data type picker
		        .ImageAttribute {
		            gx-multimedia-upload-class: multimedia-upload;
		            gx-multimedia-upload-change-class: multimedia-upload__change;
		            gx-multimedia-upload-empty-class: multimedia-upload__clear;
		            gx-readonly-class: ROImageAttribute;
		        }
		         //Audio data type picker
		        .AudioAttribute {
		            @include ImageAttribute;
		        }
		        //Video data type picker
		        .VideoAttribute {
		            @include ImageAttribute;
		        }
		        .multimedia-upload {
		            border-color: $colors.un-border-color__strong;
		            border-style: solid;
		            border-width: 1px;
		            border-radius: $radius.un-radius--m;
		            position: relative;
		            height: 85px;
		            width: 150px;
		            display: block;
		            text-align: center;
		            line-height:68px;
		        }
		        .multimedia-upload__change {
		            background-image: gx-image(GeneXusUnanimo.edit_light);
		            background-repeat: no-repeat;
		            background-position: center;
		            font-size: 0px;
		            position: absolute;
		            width: 28px;
		            height: 28px;
		            inset-inline-end: 30px;
		            border-radius: $radius.un-radius--s;
		        }
		        .gx-multimedia-upload .change-action {
		            background-color: $colors.surface-transp;
		        }
		        .gx-multimedia-upload .change-action:hover {
		            background-color: rgba(105, 110, 242, 0.2);
		        }
		        .multimedia-upload__clear {
		            
		        } 
		        .gx-multimedia-upload .clear-action {
		            @include multimedia-upload__change;
		            background-image: gx-image(GeneXusUnanimo.delete_light);
		            inset-inline-end: 0px;
		        }
		        .gx-multimedia-upload .clear-action {
		            background-color: $colors.surface-transp;
		        }
		        .gx-multimedia-upload .clear-action:hover {
		            background-color: rgba(105, 110, 242, 0.2);
		        }
		        .gx-multimedia-ro .form-control-static {
		            min-height: unset;
		            padding: 0;
		        }
		        //placeholder when multimedia has value
		        DIV.gx-multimedia-upload A.gx-multimedia-download SPAN.gx-download-placeholder {
		            background-image: gx-image(GeneXusUnanimo.projects);
		            background-repeat: no-repeat;
		            background-position: center;
		            opacity: 1;
		            height: 64px;
		            display: block;
		        }
		        .ROImageAttribute {
		            border-width: 0;
		            width: 50px;
		            max-width: 124px;
		            max-height: 68px;
		        }
		        .ImageAttribute.gx-disabled {
		            padding-block: 7px;
		            border-width: 0;
		            width: 40px;
		            max-width: 124px;
		            max-height: 68px;
		        }
		        img.Attribute {
		            max-width: 64px;
		            padding-block: 7px;
		        }
		        img.DisplayAttribute {
		            max-width: 24px;
		        }
		        //Download Attribute (blobfile)
		        .DownloadAttribute {
		            gx-multimedia-upload-class: multimedia-upload;
		            gx-multimedia-upload-change-class: multimedia-upload__change;
		            gx-multimedia-upload-empty-class: multimedia-upload__clear;
		        }
		        img.DownloadAttribute {
		            max-width: 36px;
		            padding-block: 7px;
		        }
		        span.DownloadAttribute {
		            display: inline-block;
		            background-image: gx-image(GeneXusUnanimo.download_ico);
		            background-repeat: no-repeat;
		            background-position: center 7px; 
		            border-width: 0;
		            height: 32px;
		            width: 32px;
		        }
		        A:not([href]) span.gx-download-placeholder {
		            opacity: $opacity.m;
		        }
		        DIV.gx-multimedia-upload A.gx-multimedia-empty SPAN.gx-download-placeholder {
		            background-image: gx-image(GeneXusUnanimo.video);
		            opacity: 1;
		        } 
		        DIV.gx-multimedia-upload * {
		            line-height:normal;
		        }
		        DIV.gx-multimedia-upload IMG {
		            padding-top: 5px;
		            vertical-align: middle;
		            max-height: 78px;
		            max-width: 140px;
		        }
		        DIV.gx-multimedia-upload DIV.fields-ct {
		            background-color: $colors.overlay-bg; 
		            border-bottom-right-radius: 8px;
		            border-bottom-left-radius: 8px;
		            padding-block: 20px;
		            padding-inline: 30px;
		            height: 100%;
		            display: none;
		            white-space: nowrap;
		        }
		        DIV.gx-multimedia-upload DIV.fields-ct .Button:first-child {
		            display: block;
		            margin-inline-start: auto;
		            margin-inline-end: $spacing.un-l;
		            margin-top: $spacing.un-xl;
		        }
		        DIV.gx-multimedia-upload DIV.fields-ct .Button {
		            display: block;
		            margin-top: $spacing.un-xl;
		        }
		        DIV.fields-ct .Button:hover { 
		             cursor: pointer;
		        }
		        .fields-ct .row:first-child {
		            display: flex;
		            flex-direction: column;
		        }
		        .fields-ct .row:last-child div{
		            display: flex;
		        }
		        //upload file modal dialog
		        DIV.gx-multimedia-upload INPUT.field {
		            @include Attribute;
		            border-style: solid;
		            border-width: 1px;
		            float: none;
		            margin-top: 23px;
		            max-height: none;
		            width: 400px;
		            max-width: none;
		            display: none;
		        }
		        DIV.gx-multimedia-upload INPUT.field-selected {
		            display: inline;
		        }
		        label.option {
		            @include attribute-label;
		            display: block;
		            padding-bottom: 4px;
		        }
		        label.option:hover {
		            cursor: pointer; 
		        }
		        DIV.suggestions {
		            position: absolute;
		            font-size: $fontSizes.un-s;
		            font-family: $fonts.un-font__family;
		            color: $colors.un-text__on-surface--negative;
		            background-color: $colors.un-surface--positive;
		            border-radius: $radius.un-radius--l;
		            padding-block: 4px;
		            box-shadow: $shadows.s;
		        }
		        DIV.suggestions DIV.current {
		            background-color: $colors.un-accent__primary-dim--hover;
		        }
		        DIV.suggestions DIV {
		            cursor: pointer;
		            padding-inline-start: 4px;
		            padding-inline-end: 4px;
		            margin-inline-start: 4px;
		            margin-inline-end: 4px;
		        }
		        //choose file button
		        input[type="file"].field {
		            border-style: none !important;
		        }
		        input[type="file"].field::before {
		            position: absolute;
		            pointer-events: none;
		            top: 25px;
		            left: 24px;
		            height: 24px;
		            width: 24px;
		            content: "";
		            background-image: gx-image(GeneXusUnanimo.upload_ico);
		            background-repeat: no-repeat;
		            background-position: center center; 
		        }
		        .field::file-selector-button {
		            @include button-primary;
		            height: 28px;
		            padding-inline-start: $spacing.un-xl;
		            padding-inline-end: $spacing.un-m;
		            border-radius: $radius.un-radius--s;
		        }
		        .field::file-selector-button:hover {
		            cursor: pointer;
		        }
		    #endregion
		
		    #region Calendar
		        .datepicker-image{
		            content: gx-image(GeneXusUnanimo.calendar_ico);
		        }
		
		        .dp_container img {
		            content: gx-image(GeneXusUnanimo.calendar_ico);
		            border-radius : 0;
		            padding : 2px;
		            width : 28px;
		            height : 28px;
		        }
		        .input-group span.input-group-btn {
		            float: left;
		        }
		        body[dir="rtl"] .input-group span.input-group-btn {
		            float: right;
		        }
		        .input-group span.input-group-btn .btn{
		            border-radius: 0;
		            padding: 2px;
		            width: 28px;
		            height: 28px;
		            display: flex;
		            align-items: center;
		            justify-content: center;
		            margin-inline-start: 3px;
		            gx-button-hovered-class: button-secondary--hover;
		            gx-button-focused-class: button-secondary--focused;
		        }
		        .input-group span.input-group-btn .btn img{
		            //width:20px;
		        }
		        .calendar {
		            background-color: $colors.overlay-bg;
		        }
		        .calendar table {
		            color: $colors.un-text__on-surface--positive;
		            border-spacing: 1px;
		            padding: 2px;
		            border: 0;
		            box-shadow: $shadows.xs;
		        }
		        .calendar thead .daynames {
		            line-height: 0;
		        }
		        .calendar thead .name {
		            text-transform: uppercase;
		            color: $colors.un-text__primary;
		            font-size: 0;
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--semibold;
		            min-width: 21px;
		            padding-top: $spacing.un-l;
		        }
		        .calendar thead .name::first-letter {
		            font-size: $fontSizes.un-s;
		        }
		        .calendar thead .calendartitle {
		            background-color: $colors.overlay-bg;
		            text-transform: uppercase;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-xs;
		            color: $colors.un-text__on-surface--positive;
		        }
		        .calendar thead .calendarbutton.calendar-nav {
		            font-size: $fontSizes.un-xxl;
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--light;
		        }
		        .calendar .calendarbutton {
		            background: $colors.overlay-bg;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		        }
		        .calendar thead tr:first-child td:first-child {
		            font-size:$fontSizes.un-s;
		        }
		        .calendar .headrow .calendarbutton {
		            line-height: 0.45em;
		            font-size: $fontSizes.un-xs;
		        }
		        .calendar tbody .day {
		            border-color: $colors.un-border-color__mild;
		            height: $spacing.un-xl;
		            width: $spacing.un-xl;
		            text-align: center;
		            background: $colors.overlay-bg;
		            font-size: $fontSizes.un-xs;
		            font-family: $fonts.un-font__family;
		        }
		        .calendar tbody td.today {
		            text-decoration: none;
		        }
		        .calendar tbody .day:hover {
		            border-color: $colors.un-border-color__primary;
		        }
		        .calendar tbody td.selected {
		            border-color: $colors.un-border-color__primary;
		            color: $colors.un-text__on-surface--positive;
		            background-color: rgba(105, 110, 242, 0.1);
		            text-decoration: none;
		        }
		        //time
		        .time .hour {
		            background: transparent;
		            border: 0px;
		            font-family: $fonts.un-font__family;
		            font-weight: lighter;
		        }
		        .time .colon {
		            font-family: $fonts.un-font__family;
		            font-weight: lighter;
		        }
		        .time .minute {
		            background: transparent;
		            border: 0px;
		            font-family: $fonts.un-font__family;
		            font-weight: lighter;
		        }
		        //Calendar Combo
		        .calendar .calendarcombo .label {
		            display: block;
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--light;
		            font-size: $fontSizes.un-xs;
		            color: $colors.un-text__on-surface--positive;
		            border-radius: 0;
		        }
		        .calendar .calendarcombo .label:hover {
		            background-color: $colors.un-accent__primary;
		            color: $colors.un-text__on-primary;
		        }
		        .calendar .calendarcombo {
		            top: 42px;
		            width: 2.5em;
		            transform: translateX(2px);
		        }
		    #endregion
		    
		    #region Grid 
		        .Grid label.Attribute {
		            padding: 0px;
		            min-height: unset;
		            background-color: transparent;
		            border: none;
		        }
		        .ww__grid label.Attribute {
		            padding: 0px;
		            min-height: unset;
		            background-color: transparent;
		            border: none;
		        }
		        .Grid .gx_newrow {
		            @include button-secondary;
		            display: inline-block;
		            height: 28px;
		            margin-block: $spacing.un-m;
		            padding: 5px  $spacing.un-l 5px $spacing.un-l;
		            border-radius: $radius.un-radius--s;
		            text-decoration: none;
		        }
		        .gx_newrow-focus-class {
		            outline: none;
		        }
		        .Grid .gx_newrow:before {
		            content: "+";
		            margin-inline-end: $spacing.un-s;
		        }
		        .gx-grid-delete {
		            width: 12px;
		            margin-inline-end: $spacing.un-s;
		        }
		        .form-control-static {
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            margin: 0px;
		            min-height: 34px;
		            padding-block: 7px;
		        }
		        .GridHighlightedRow{
		            background-color: $colors.form-container-bg;
		            color: $colors.un-text__on-surface--positive;
		            border-collapse: collapse;
		            margin-top: 5px;
		            margin-bottom: 10px;
		            cursor: default;
		            gx-grid-row-class: grid-row-highlight;
		        }
		        //Highlighted row
		        .GridHighlightedRow .GridHighlightedRowTitle {
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--bold;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		            border-bottom-width: $borders.un-width--xs;
		            border-bottom-style: solid;
		            border-bottom-color: $colors.un-border-color__mild;
		            padding-block: 7px;
		            padding-inline-start: $spacing.un-m;
		            padding-inline-end: $spacing.un-m;
		        }
		        .GridHighlightedRowTitle {
		            cursor: pointer;
		        }
		        .GridHighlightedRow .form-control-static {  
		            padding-block: 9px;
		        }
		        .GridHighlightedRow .gx-attribute {
		            padding-inline-start: $spacing.un-m;
		            padding-inline-end: $spacing.un-m;
		        }
		        //empty Grid text
		        .GridNoDataText {
		            color: rgb(18, 18, 18);
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            letter-spacing: 0.25px;
		            line-height: 16px;
		            background-color: $colors.un-surface--positive;
		            margin-top: 20px;
		        }
		        .gx-grid [data-gx-grid-nodata] + .GridNoDataText {
		            color: $colors.un-text__on-surface--positive;
		            background-color: transparent;
		            display: flex;
		            flex-direction: column;
		            gap: 16px;
		            align-items: center;
		            margin-block-start: 0px;
		        }
		        //Chat Grid
		        .chat__grid {
		            @include Grid;
		            padding-block: 0px;
		            border: none;
		        }
		        .chat__grid + .GridNoDataText {
		            @include GridNoDataText;
		        }
		        .chat__grid + .GridNoDataText::before {
		            //content: gx-image(chat_empty_grid);
		        }
		
		        .gx-grid [data-gx-grid-nodata] {
		            //margin-bottom: 0px;
		        }
		        //WW Trn Level Grid
		        .WorkWith,.PromptGrid,.ViewGrid {
		            text-align: start;
		            table-layout: fixed;
		            border-collapse: collapse;
		        }
		        .ViewGrid {
		            width: 100%;
		            margin-top: $spacing.un-l;
		        }
		        .ViewGrid, .GridWithBorder {
		            background-color: $colors.form-container-bg;
		            border-collapse: collapse;
		        }
		        .ViewGridTitle, .Grid, .GridWithBorder {
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		        }
		    #endregion
		
		    #region Grid Row
		        .grid-row-highlight {
		            gx-table-row-hovered-class: TableRowHovered;
		        } 
		    #endregion
		
		    #region Grid Column
		        .gx-grid th > span {
		            display: flex; 
		            align-items: center;  
		        }
		        .gx-grid th[style*="text-align:end"] > span {
		            justify-content: end;
		        }
		        .column-action {
		            text-align: center !important;
		            width: 50px;
		            padding: 7px;
		            border-bottom-width: 1px;
		            border-bottom-color: $colors.un-border-color__mild;
		            border-bottom-style:solid;
		        }
		        .column-action .gx-image-link .attribute-action {
		            padding-block: 8px;
		            border-width: 0;
		            width: 40px;
		            max-width: 124px;
		            max-height: 68px;
		        }
		        .WWTextActionColumn {
		            width: 80px;
		            border-bottom-width: 1px;
		            border-bottom-color: $colors.un-border-color__mild;
		            border-bottom-style:solid;
		        }
		        //in grid Image
		        .gx-grid > img {
		            max-height: 48px;
		        }
		        //center images vertically when inside a grid column
		        td.gx-tab-padding-fix-1.gx-attribute img {
		            vertical-align: middle;
		        }
		        td.gx-attribute .form-control {
		            display: inline-block;
		            width: 100%;
		            margin-top: 5px;
		            margin-bottom: 5px;
		        }
		        td.gx-attribute .dp_container .Attribute {
		            display: inline-block;
		            border-width: 1px;
		            margin-top: 5px;
		            margin-bottom: 5px;
		        }
		        @media screen and (max-width: 767px) {
		            .OptionalColumn {
		                display: none;
		            }
		            .WWOptionalColumn {
		                display: none;
		            }
		            td.gx-attribute .form-control {
		                width: 100%;
		            }
		        }
		    #endregion
		
		    #region Prompt
		        .gx-prompt {
		            content: gx-image(GeneXusUnanimo.prompt_light); 
		        }
		        .SelectionAttribute {
		            content: gx-image(GeneXusUnanimo.featured_green);
		        }
		        .PromptMainTable {
		            background-color: $colors.overlay-bg;
		        }
		        .PromptAdvancedBarCell {
		            border-inline-end-width: 1px;
		            border-inline-end-style: solid;
		            border-inline-end-color: $colors.un-border-color__mild;
		        }
		        .PromptGrid {
		            @include Grid;
		            width: 100%;
		        }
		        .PromptGrid .gx-attribute {
		            padding-inline-start: $spacing.un-m;
		            padding-inline-end: $spacing.un-m;
		        }
		        .PromptGrid .PromptGridTitle {
		            padding-inline-start: $spacing.un-m;
		            padding-inline-end: $spacing.un-m;
		        }
		        .PromptGridTitle {
		            position: relative;
		        }
		        .PromptGridTitle img{
		            position: absolute;
		            right:0;
		        }
		        //Prompt Grid Footer
		        .PromptGridFooter {
		            padding-top: $spacing.un-m;
		        }
		        .GridHeaderRowPromptGrid {
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--bold;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		            cursor: pointer;
		        }
		        .PromptGridGridRow {
		            border-bottom-width: 1px;
		            border-bottom-style: solid;
		            border-bottom-color: $colors.un-border-color__mild;
		            border-width: 3px;
		            border-inline-start-style: solid;
		            border-inline-start-color: transparent;
		            border-bottom: 0;
		            gx-table-row-hovered-class: TableRowHovered;
		        }
		        .PromptGridOdd td {
		            padding-block: 3px;
		        }
		        .BtnToggle {
		            @include ww__button-filters--show;
		            background-color: transparent;
		        }
		        .AdvancedContainer {
		            visibility: hidden;
		            padding-inline-end: 20px;
		            position: absolute;
		            z-index: 10;
		            background-color: $colors.overlay-bg;
		            width: 100%;
		            min-height:  calc(100vh - 206px);
		            transition: visibility 0s linear 0s, opacity 300ms;
		        }
		        .AdvancedContainerVisible {
		            @include AdvancedContainer ;
		            visibility: visible;
		            display: inherit;
		        }
		        @media screen and (max-width: 767px) {
		            .BtnToggle {
		                margin-top: $spacing.un-m;
		                margin-bottom: $spacing.un-m;
		            }
		            //use the opposite behavior to hide the advanced filters on mobile screens by default
		            .PromptContainer .AdvancedContainerVisible {
		                visibility: hidden !important;
		            }
		            .PromptContainer .AdvancedContainer {
		                top: 38px;
		                width: 260px;
		                padding: $spacing.un-m;
		                border: solid $borders.un-width--xs lightgray;
		                box-shadow: $shadows.s;
		                border-radius: $radius.un-radius--l;
		                visibility: visible;
		            }
		        }
		    #endregion
		
		    #region Table
		        .Table {
		            text-align: start;      
		        }
		        .Grid, .FreeStyleGrid, .GridWithBorder, .PromptGrid {
		            background-color: $colors.form-container-bg;
		            color: $colors.un-text__on-surface--positive;
		            border-collapse: collapse;
		            margin-top: $spacing.un-s;
		            margin-bottom: $spacing.un-m;
		            cursor: default;
		        }
		        .GridWithBorder {
		            gx-grid-row-class: grid-row;
		        }
		        .GridTitle {
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--bold;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		            cursor: pointer;
		            border-bottom: $borders.un-width--xs solid $colors.un-border-color__mild;
		            padding-block: 7px;
		            padding-inline: $spacing.un-m;
		        }
		        .Grid {
		            gx-grid-header-row-class: GridTitle;
		            gx-grid-row-class: grid-row;
		        }
		        .Grid .form-control-static {  
		            padding-block: 9px;
		        }
		        .GridWithBorder .GridWithBorderTitle {
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--bold;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		            cursor: pointer;
		            border-bottom: $borders.un-width--xs solid $colors.un-border-color__mild;
		            padding-block: 7px;
		            padding-inline: $spacing.un-m;
		        }
		        .GridWithBorder .form-control-static {  
		            padding-block: 9px;
		        }
		        .GridWithBorder thead {
		            border-top: $borders.un-width--xs solid $colors.un-border-color__mild;
		            border-inline-start: $borders.un-width--xs solid $colors.un-border-color__mild;
		            border-inline-end: $borders.un-width--xs solid $colors.un-border-color__mild;
		        }
		        .GridWithBorder tbody {
		            border-top: $borders.un-width--xs solid $colors.un-border-color__mild;
		            border-inline-start: $borders.un-width--xs solid $colors.un-border-color__mild;
		            border-inline-end: $borders.un-width--xs solid $colors.un-border-color__mild;
		        }
		        .GridWithBorder tfoot {
		            border-inline-start: $borders.un-width--xs solid $colors.un-border-color__mild;
		            border-inline-end: $borders.un-width--xs solid $colors.un-border-color__mild;
		            border-bottom: $borders.un-width--xs solid $colors.un-border-color__mild;
		        }
		        .gx-freestyle-grid .form-control-static {
		            padding-block: 10.5px;
		        }
		        .gx-freestyle-grid .form-control {
		            margin-top: 6px;
		            margin-bottom: 5px;
		        }
		        .Grid .gx-attribute { 
		            padding-inline: $spacing.un-m;
		        }
		        .GridWithBorder .gx-attribute {
		            padding-inline: $spacing.un-m;
		        }
		        //freestyle grid row border
		        .Grid > .row {
		            border-bottom-width: $borders.un-width--xs;
		            border-bottom-style: solid;
		            border-bottom-color: $colors.un-border-color__mild;
		        }
		        .GridWithBorder > .row {
		            border-bottom-width: $borders.un-width--xs;
		            border-bottom-style: solid;
		            border-bottom-color: $colors.un-border-color__mild;
		        }
		        .collapse-icon, .expand-icon {
		            width: 17px;
		            content: gx-image(GeneXusUnanimo.minus);
		        }
		        .expand-icon {
		            content: gx-image(GeneXusUnanimo.plus);
		        }
		        @media screen and (max-width: 767px) {
		            .gx-freestyle-grid .form-control-static {
		                padding-block: $spacing.un-s;
		                min-height: 10px;
		            }
		            .gx-freestyle-grid .row {
		                padding-block: $spacing.un-s;
		            }
		        }
		    #endregion
		
		    #region Checkbox
		        .gx-checkbox-wrapper > input {
		            margin-inline-start: 0px;
		        }
		        //clear all default styles
		        input[type="checkbox"] {
		            -webkit-appearance: none;
		            appearance: none;
		            margin: 0px;
		        }
		        input[type="checkbox"]:hover {
		            cursor: pointer;
		        }
		        input[type="checkbox"]:focus {
		            outline: none;
		        }
		        input[type="checkbox"]:focus:after {
		            border-width:2px;
		        }
		        input[type="checkbox"]:after {
		            content: '';
		            display: inline-block;
		            vertical-align: text-top;
		            width: 16px;
		            height: 16px;
		            background: transparent;
		            border-color: $colors.un-border-color__strong;
		            border-style: solid;
		            border-width: $borders.un-width--xs;
		            border-radius: $radius.un-radius--m;
		            background-color: $colors.attribute-bg;
		        }
		        input[type="checkbox"]:disabled:after {
		            background-color: $colors.un-accent__disabled; 
		        }
		        .gx-checkbox-wrapper input[checked]:after {
		            border-color: $colors.un-border-color__primary;
		        }
		        .gx-checkbox-wrapper input[checked]:before {
		            content: "";
		            display: inline-block;
		            width: 5px;
		            height: 9.5px;
		            border-style: solid;
		            border-color: $colors.un-border-color__primary;
		            border-top-width: 0;
		            border-inline-end-width: 2px;
		            border-bottom-width: 2px;
		            border-inline-start-width: 0;
		            transform: rotate(45deg);
		            -webkit-transform: rotate(45deg);
		            -ms-transform: rotate(45deg);
		            border-radius: 0px;
		            margin-top: 0px;
		            margin-inline-end: 15px;
		            margin-inline-start: 5px;
		            margin-bottom: 5px;
		            inset-inline-start: .5px;
		            top: 2px;
		            position: absolute;
		        }
		        .gx-checkbox-wrapper {
		            background-color: transparent;
		            border: none;
		            padding: 0;
		            padding-top: $spacing.un-s;
		        }
		        //in Grid checkbox
		        .gx-grid input[type="checkbox"][checked]::after {
		            clip-path: polygon(21% 40%, 21% 40%, 8% 54%, 25% 68%, 36% 77%, 47% 65%, 48% 64%, 64% 47%, 75% 35%, 93% 13%, 81% 4%, 36% 54%);
		            width: 12px;
		            height: 12px;
		            background-color: $colors.un-accent__primary;
		            position: relative;
		            top: 2px;
		            inset-inline-start: 1px;
		        }
		        .gx-grid input[type="checkbox"][checked] {
		            border: solid $borders.un-width--xs $colors.un-border-color__primary;
		            border-radius: $radius.un-radius--m;
		            width: 16px;
		            height: 16px;
		        }
		        .gx-grid input[type="checkbox"]:disabled {
		            background-color: $colors.un-accent__disabled;
		        }
		        //checkbox title
		        [data-gx-checkbox-title] {
		            margin-inline-start: 22px;
		        }
		    #endregion
		 
		    #region Radio Button
		        //clear all default styles
		        input[type="radio"] {
		            -webkit-appearance: none;
		            appearance: none;
		        }
		        //custom style (overwriting browser's default)
		        input[type="radio"] {
		            margin-inline-end: 8px;
		        }
		        input[type="radio"]:focus {
		            outline: none;
		            box-shadow: 0px 0px 0px 3px black;
		            width: 17px;
		            height: 17px;
		            border-radius: 10px;
		
		        }
		        input[type="radio"]:after {
		            width: 15px;
		            height: 15px;
		            border-radius: 15px;
		            position: relative;
		            inset-inline-start: 1px;
		            top: 1px;
		            background-color: $colors.attribute-bg;
		            content: '';
		            display: inline-block;
		            visibility: visible;
		            border: 1px solid;
		            border-color: $colors.un-border-color__strong;
		            cursor: pointer;
		        }
		        //checked
		        input[type="radio"]:checked:after {
		            background-color: $colors.un-accent__primary;
		            content: '';
		            display: inline-block;
		            visibility: visible;
		            border: 3px solid;
		            border-color: $colors.un-surface--positive;
		            cursor: pointer;
		            box-shadow: 0px 0px 1px 2px;
		            color: $colors.un-text__primary;
		        }
		        .gx-radio-button {
		            display: block;
		            margin-block-start: 7px;
		            padding: 4px;
		            padding-block-start: 5px;
		            background-color: transparent;
		            border: none;
		        }
		        .gx-radio-button-vertical {
		            height: auto;
		        }
		        .gx-radio-label { 
		            font-size: $fontSizes.un-s;
		            padding-inline-end: $spacing.un-m;
		            gx-attribute-hovered-class: gx-radio-label--hover;
		            gx-attribute-highlighted-class: gx-radio-label--active;
		        }
		        .gx-radio-label--hover {
		            cursor: pointer;
		        }
		        .gx-radio-label--active {
		            border-color: $colors.un-border-color__primary--active;
		        }
		        .gx-radio-label:hover:active {
		            box-shadow: none;
		            border-color: $colors.un-border-color__primary--active;
		        }
		        .gx-radio-label.active {
		            box-shadow: none;
		            background-color: $colors.un-accent__primary;
		            color: $colors.un-text__on-primary;
		        }
		        //disabled
		        input[type="radio"]:disabled:after {
		            background-color: $colors.un-accent__disabled;
		            color: $colors.un-color__gray--600;
		        }
		    #endregion
		
		    #region File Upload
		        .gx-fileupload .table {
		            width: 100%;
		            background-color: $colors.form-container-bg;
		            margin-block-start: $spacing.un-m;
		        }
		        .gx-fileupload {
		            @include card inset-m;
		            max-width: 392px;
		        }
		        .fileupload-buttonbar .col-lg-7 {
		            display: flex;
		            gap: $spacing.un-m;
		        }
		        .fileupload-buttonbar::after {
		            content: "or";
		            color: $colors.un-text__on-surface--positive;
		            padding-block: $spacing.un-m; 
		            padding-inline-start: $spacing.un-l;
		        }
		        .gx-fileupload .dropzone {
		            min-height: 120px;
		            width: 360px;
		            border: 1px solid $colors.un-border-color__primary;
		            background-color: $colors.un-accent__primary-dim--hover;
		        }
		        .gx-fileupload .dropzone.hover {
		            border: 4px dashed $colors.un-border-color__primary;
		        }
		        .gx-fileupload .dropzone.in {
		            font-size: unset;
		        }
		        .FileUpload .fileinput-button {
		            @include Button;
		            padding-top: 4px;
		        }
		        .FileUpload .start {
		            @include Button; 
		            min-width: 28px;
		            padding: 0px;
		            background-image: gx-image(GeneXusUnanimo.upload_ico);
		            background-position: center;
		            background-repeat: no-repeat;
		            cursor: pointer;
		        }
		        .FileUpload .cancel[disabled] {
		            background-image: gx-image(GeneXusUnanimo.close_ico_disabled);
		        }
		        .FileUpload .cancel {
		            @include Button button-tertiary;
		            min-width: 28px;
		            padding: 0px;
		            background-image: gx-image(GeneXusUnanimo.close_ico_light);
		            background-position: center;
		            background-repeat: no-repeat;
		            cursor: pointer;
		        }
		        //Dropzone
		        .gx-fileupload .dropzone {
		            position: unset;
		            display: flex;
		            align-items: center;
		            justify-content: center;
		        }
		        .gx-fileupload .dropzone span {
		            display: block;
		            color: $colors.un-text__primary;
		            text-transform: uppercase;
		            position: unset;
		            transform: none;
		        }
		        .FileUpload .template-upload,
		        .FileUpload .template-download {
		            font-size: $fontSizes.un-s;
		            font-family: $fonts.un-font__family;
		            color: $colors.un-text__on-surface--positive;
		        }
		        //Uploaded files list
		        .template-upload {
		            display: flex;
		            align-items: center;
		            gap: $spacing.un-m;
		            border-block-end: solid 1px $colors.un-border-color__mild;
		        }
		        .template-upload__column-preview canvas {
		            width: 60px;
		            max-height: 40px;
		            margin-block-start: $spacing.un-s;
		        }
		        .template-upload__column-name {
		            flex-grow: 1;
		        }
		        .template-upload__column-size {
		            display: flex;
		            flex-direction: column;
		            gap: $spacing.un-s;
		        }
		        .template-upload__column-size .size {
		            margin: 0px;
		        }
		        .template-upload__column-actions {
		            display: flex;
		            align-items: center;
		            gap: $spacing.un-s;
		        }
		        .template-upload__column-actions .btn {
		            margin-bottom: 0px;
		        }
		        //Progress bar
		        .gx-fileupload .progress {
		            height: $spacing.un-s;
		            background-color: $colors.un-color__gray--500;
		        }
		        .progress-bar-success {
		            background-color: $colors.un-accent__primary;
		        }
		        //Progress extended
		        .progress-extended {
		            font-size: $fontSizes.un-s;
		            font-family: $fonts.un-font__family;
		            margin-top: $spacing.un-s;
		        }
		        //Error text
		        .text-danger {
		            color: $colors.un-text__error;
		        }
		        //Error label
		        .label-danger {
		            @include badge;
		            background-color: $colors.un-color__red--100;        
		            border-color: $colors.un-border-color__error;
		            background-image: gx-image(GeneXusUnanimo.dot_red); 
		            margin-inline-end: $spacing.un-m;
		            color: black;
		        }
		        //Image preview
		        .FileUpload .preview {
		            padding-top: $spacing.un-m;
		        }
		    #endregion
		
		    #region Select
		        select {
		            padding-inline-start: 4px !important;
		        }
		        select.ErrorAttribute {
		            appearance: none;
		            padding-inline-end: 30px;
		        }
		        select.Attribute {
		            height: auto;
		        }
		        //FF
		        select.Attribute {
		            scrollbar-color: $colors.un-accent__secondary--active $colors.un-color__gray--300;
		            scrollbar-width: thin;
		        }
		        //Chrome, Edge
		        select.Attribute::-webkit-scrollbar {
		            width: 5px;
		        }
		        select.Attribute::-webkit-scrollbar-track {
		            border-radius: 3px;
		            background-color: $colors.un-color__gray--300;
		        } 
		        select.Attribute::-webkit-scrollbar-thumb {
		            border-radius: 3px;
		            background-color: $colors.un-accent__secondary--active;
		        }
		        select option {
		            color: $colors.un-text__on-surface--positive;
		            background-color: $colors.attribute-select-bg;
		        }
		    #endregion
		
		    #region Progress Indicator
		        //Overwrite bootstrap's default 
		        .progress {
		            height: 12px;
		            background-color: $colors.un-color__gray--400;
		        }
		        .progress-bar {
		            background-color: $colors.un-accent__primary;
		            display: flex;
		            align-items: center;
		            justify-content: center;
		            font-size: $fontSizes.un-xs;
		            color: $colors.un-text__on-primary;
		        }
		        .progress-striped .progress-bar {
		            background-image: none;
		        }
		        .progress-bar-title {
		            display: inline-block;
		            padding-bottom: 5px;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		        }
		    #endregion
		 
		    #region Tab
		        .nav-tabs>LI {
		            display: inline-block;
		        }
		        .Tab {
		            gx-tab-item-class: tab-item;
		        }
		        div.Tab UL.nav-tabs LI.active A {
		            border-bottom: solid;
		            border-bottom-width: 3px;
		            border-bottom-color: $colors.un-border-color__primary--active;
		            text-decoration: none;
		        }
		        div.Tab UL.nav-tabs LI A:hover {
		            border-bottom: solid;
		            border-bottom-color: $colors.un-border-color__secondary;
		        }
		        div.Tab UL.nav-tabs LI A:focus {
		            outline: solid 1px;
		            outline-color: $colors.un-border-color__primary--active;
		        }
		        //WorkWith tab
		        div.ww__view__tab UL.nav-tabs LI A:hover {
		            border-bottom: solid;
		            border-bottom-color: $colors.un-border-color__secondary;
		        }
		        //WorkWith tab
		        div.ww__view__tab UL.nav-tabs LI A:focus {
		            outline: solid 1px;
		            outline-color: $colors.un-border-color__primary--active;
		        }
		        div.ww__view__tab UL.nav-tabs LI.active A {
		            border-bottom-color: $colors.un-border-color__primary--active;
		            border-bottom-style: solid;
		            text-decoration: none;
		            color: $colors.un-text__on-surface--positive;
		        }
		        .tab-content {
		            @include card;
		            box-shadow: none;
		            padding: $spacing.un-l;
		        }
		    #endregion
		    
		    #region Scrollbar
		        body::-webkit-scrollbar-track
		        {
		            border-radius: 10px;
		            background-color: $colors.un-color__gray--300;
		        }
		        body::-webkit-scrollbar
		        {
		            width: 10px;
		            height: 10px;
		            background-color: #F5F5F5;
		        }
		        body::-webkit-scrollbar-thumb
		        {
		            border-radius: 10px;
		            background-color: $colors.un-accent__secondary--active;
		        }
		    #endregion
		
		    #region new classes
		        //arrow icons
		        .ico__arrow-first {
		            background-image: gx-image(GeneXusUnanimo.arrow_first);
		            background-position: center center;
		        }
		        .ico__arrow-prev {
		            background-image: gx-image(GeneXusUnanimo.arrow_left);
		            background-position: center center;
		        }
		        .ico__arrow-next {
		            background-image: gx-image(GeneXusUnanimo.arrow_right);
		            background-position: center center;
		        }
		        .ico__arrow-last {
		            background-image: gx-image(GeneXusUnanimo.arrow_last);
		            background-position: center center;
		        }
		        body[dir="rtl"] [class*="ico__arrow"] {
		            transform: rotate(180deg);
		        }
		        .attribute-filter {
		            gx-label-class: attribute-label;
		            width: 100%;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            padding-inline-start: $spacing.un-m;
		            padding-inline-end: $spacing.un-m;
		            gx-attribute-focused-class: AttributeFocusedClass;
		            background-color: $colors.attribute-bg;
		        }
		        .attribute-search {
		            @include attribute-filter;
		            height: 28px;
		            border-color: $colors.un-border-color__strong; 
		            color: $colors.un-text__on-surface--positive;
		            border-radius: $radius.un-radius--m;
		            background-image: gx-image(GeneXusUnanimo.search);
		            background-repeat: no-repeat;
		            background-position: 0px 1px;
		            background-color: $colors.attribute-bg;
		            padding-inline-start: $spacing.un-xl;
		            gx-datepicker-image-class: datepicker-image;
		        }
		        body[dir="rtl"] .attribute-search {
		            background-position: right;
		        }
		        textarea.attribute-search {
		            padding-top: 4px;
		        }
		        select.attribute-search {
		            background-image: none;
		        }
		        .TextActionAttribute { 
		            gx-attribute-link-class: TextActionAttribute;
		            background-color: transparent;
		            font-size: $fontSizes.un-s;
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--semibold;
		            color: $colors.un-text__primary;
		            text-transform: uppercase;
		            border:none;
		            border-radius: 0;
		            padding-inline-start: $spacing.un-m;
		            padding-inline-end: $spacing.un-m;
		        }
		        .TextActionAttribute>A {
		            text-decoration: none;
		        }
		        .TextActionAttribute>A:hover {
		            @include TextActionAttribute;
		            background-color: $colors.un-accent__primary-dim--hover !important;
		            padding-block: 4px;
		        }
		        //to review
		        .Errorattribute-search {
		            @include attribute-search;
		            height: 28px;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-s;
		            color: $colors.un-text__on-surface--positive;
		            border-radius: $radius.un-radius--m;
		            border-color: $colors.un-border-color__error;
		        }
		        //show error message in bottom position
		        .ww-filter-cell div[style]{
		            top: unset !important;
		            inset-inline-start: unset !important;
		        }
		        .attribute-combo {
		            @include attribute-filter;
		            height: 28px;
		            border-color: $colors.un-border-color__strong;
		            color: $colors.un-text__on-surface--positive;
		            border-radius: $radius.un-radius--m;
		            margin-top: $spacing.un-s;
		            margin-bottom: $spacing.un-s;
		        }
		        .ww__grid-container {
		            @include card;
		            padding: $spacing.un-l;
		            min-height: 423px;
		        }
		        .ww__grid {
		            width: 100%;
		            background-color: $colors.form-container-bg;
		            margin-top: $spacing.un-l;
		            table-layout: fixed;
		            border-collapse: collapse;
		        }
		        .ww__gridTitle span:hover{
		            cursor: pointer;
		        }
		        .ww__grid-cell {
		            padding: 0px;
		            margin-bottom: $spacing.un-xxl; 
		        }
		        .ww__grid-cell--expanded {
		            width: 100%;
		            margin-bottom: $spacing.un-xxl; 
		        }
		        .expandible-container .ww__grid-cell--expanded {
		            width: 100%;
		            padding: 0px;
		        }
		        .expandible-container .ww__title-cell {
		            margin-inline-start: 0%;
		        }
		        .ww__actions-container {
		            margin-bottom: $spacing.un-l;
		            flex-wrap: wrap;
		            row-gap: $spacing.un-m;
		        }
		        .body-container .ww__actions-container {
		            margin-bottom: $spacing.un-xxl;
		            flex-wrap: wrap;
		            row-gap: $spacing.un-m;
		            align-items: center;
		        }
		        .ww__actions-cell ul{
		            margin: 0px;
		        }
		        .ww__view__grid__actions-cell {
		            margin-inline-start: auto;
		        }
		        .ww__button-filters--show {
		            background-repeat: no-repeat;
		            background-image: gx-image(GeneXusUnanimo.filter_light);
		            background-position: center;
		            border-width: 0;
		            color: transparent;
		            z-index: 2;
		            background-color: transparent;
		            width: 28px;
		            height: 28px;
		            padding: 0px;
		            gx-button-hovered-class: button-secondary--hover;
		        }
		        .ww__button-filters--hide {
		            @include ww__button-filters--show;
		        }
		        .ww__button-filters--applied {
		            @include ww__button-filters--show;
		            background-image: gx-image(GeneXusUnanimo.filter_applied);
		        }
		        .ww__button-search {
		            @include ww__button-filters--show;
		            background-image: gx-image(GeneXusUnanimo.search_light);
		        }
		        .filters-container, .filters-container--visible {
		            visibility: hidden;
		            opacity: 0;
		            padding-inline-start: 20px;
		            padding-inline-end: 20px;
		            position: absolute;
		            inset-inline-end: -15px;
		            background-color: $colors.form-container-bg;
		            width: 100%;
		        }
		        .filters-container--visible {
		            visibility: visible;
		            opacity: 1;
		            top: -33px;
		            min-height: calc(100vh - 60px);
		            padding-top: 10px;
		            z-index: 1;
		            transition: visibility 0s linear 0s, opacity 300ms;
		        }
		        .ww__view__grid-table .filters-container--visible {
		            top: -16px;
		            right: -16px;
		            min-height: fit-content;
		            border: solid 1px $colors.un-color__gray--400;
		            padding-block-end: 32px;
		        }
		        //floating filters table (use it with a Section)
		        .filters-container-floating--visible {
		            @include filters-container--visible;
		            width: auto;
		            min-height: 200px;
		            top: 0px;
		            inset-inline-end: 15px;
		            border: solid 1px $colors.un-border-color__mild;
		        }
		        .filters-container__item {
		            border-bottom-width: $borders.un-width--xs;
		            border-bottom-style: solid;
		            border-bottom-color: $colors.un-border-color__mild; 
		            padding-block: 9px;
		            background-image: gx-image(GeneXusUnanimo.arrow_desc);
		            background-position: top 10px right;
		            background-repeat: no-repeat;
		            background-size: 20px;
		        }
		        body[dir="rtl"] .filters-container__item {
		            background-position: top 10px left;
		        }
		        .filters-container__item--expanded {
		            background-image: gx-image(GeneXusUnanimo.arrow_asc);
		        }
		        .filters-container__item .input-group {
		            display: none;
		        }
		        .filters-container__item--expanded .input-group {
		            display: flex;
		            align-items: center;
		        }
		        .filters-container__close {
		            background-repeat: no-repeat;
		            background-image: gx-image(GeneXusUnanimo.filter);
		            border-width: 0;
		            color: transparent;
		            z-index: 2;
		            width: 20px;
		            height: 20px;
		            padding: 0px;
		            margin-bottom: 20px;
		            background-color: $colors.form-container-bg;
		            background-image: gx-image(GeneXusUnanimo.close_ico);
		        }
		        .filter-item__label {
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--semibold;
		            color: $colors.un-text__on-surface--positive;
		            position: relative;
		            gx-text-block-link-class: filter-item__link;
		        }
		        .filter-item__label strong {
		            font-weight: normal;
		            font-family: $fonts.un-font__family;
		            padding-inline-start: 5px;
		        }
		        .filter-item__link {
		            @include attribute-label;
		            padding-top: 0px;
		            text-decoration: none;
		        }
		        //view form
		        .ww__view__tab {
		            gx-tab-item-class: tab-item;
		            gx-tab-page-hovered-class: tab-item--hover;
		            gx-tab-page-selected-class: tab-item--selected;
		            margin-bottom: $spacing.un-xxl;
		        }
		        .ww__view__tab .tab-content {
		            box-shadow: $shadows.xxs;
		        }
		        .ww__view__tab__form-container {
		            padding-inline-start: $spacing.un-l;
		            padding-inline-end: $spacing.un-l;
		        }
		        .ww__view__button-back {
		            background-position: 0px center;
		            background-repeat: no-repeat;
		            padding-inline-start: 28px;
		            background-image: gx-image(GeneXusUnanimo.arrow_left_light);
		            font-family: $fonts.un-font__family;
		            font-weight: $fonts.un-font__weight--semibold;
		            font-size: 14px;
		            letter-spacing: 0.25px;
		            text-align: start;
		            text-transform: uppercase;
		            gx-attribute-link-class: ww__view__button-back__link;
		        }
		        body[dir="rtl"] .ww__view__button-back {
		            background-position: right; 
		            background-image: gx-image(GeneXusUnanimo.arrow_right_light);
		        }
		        .ww__view__button-back__link {
		            color: $colors.un-text__primary;
		            text-decoration: none;
		        }
		        .ww__view__button-back>A:hover {
		            color: $colors.un-accent__primary--hover;
		        }
		        .ww__view__title-table { 
		            gap: 20px;
		            align-items: center;
		        }
		        //styling view grid
		        .ww__view__grid-table .ww__grid-cell {
		            width: 83.33333%;
		            margin: 0;
		        }
		        .ww__view__grid-table .ww__grid-cell:only-child {
		            width: 100%;
		        } 
		        .ww__view__grid-table .ww__grid-container {
		            box-shadow: none;
		            padding: 0;
		        }
		        .form__cell, .form__cell-advanced {
		            padding-block: 12px;
		            padding-inline-start: 15px;
		            border-collapse: collapse;
		            border-color: $colors.un-border-color__mild;
		            border-bottom-style: solid; 
		            border-bottom-width: 1px;
		        }
		        //Transaction's Form
		        .form-container {
		            @include card;
		            padding: $spacing.un-l;    
		            margin-bottom: 120px; 
		        }
		        .form__cell .form-group {
		            margin-bottom: 0px;
		        }
		        .form__cell-advanced .form-group {
		            margin-bottom: 0px;
		        }
		        .title-container {
		            margin-bottom: $spacing.un-l;
		        }
		        .form__actions--fixed {
		            height: 90px;
		            position: fixed;
		            bottom: 0;
		            inset-inline-end: 0;
		            z-index: 1;
		            box-shadow: 0px -1px 10px 0px rgba(0, 0, 0, 0.30);
		            background-color: $colors.footer-actions-bg;
		        }
		        .form__actions--fixed .gx-action-group {
		            padding-inline-end: $spacing.un-l;
		            flex-direction: row-reverse;
		        }
		        .form__table-level {
		            border-top-style: solid;
		            border-top-width: 32px;
		            border-top-color: $colors.un-surface--alternative;
		            width: calc(100% + 52px);
		            margin-inline-start: -26px; 
		            padding-inline: 19px;
		            padding-top: 10px;
		        }
		        .form__table-level:after {
		            content: "";
		            display:block;
		            height: 1px;
		            position:absolute;
		            border-top-width: 10px;
		            border-top-style: solid;
		            border-top-color: $colors.form-container-bg;
		            width: calc(100% + 2px);
		            inset-inline-start: -1px;
		            top: 0;
		            border-bottom-left-radius: $radius.un-radius--l;
		            border-bottom-right-radius: $radius.un-radius--l;
		            box-shadow: $shadows.xxs;
		        }
		        .form__table-level:before {
		            content: "";
		            display:block;
		            height: 1px;
		            position:absolute;
		            border-top-width: 10px;
		            border-top-style: solid;
		            border-top-color: $colors.form-container-bg;
		            width: calc(100% + 2px);
		            inset-inline-start: -1px;
		            top: 23px;
		            border-top-left-radius: $radius.un-radius--l;
		            border-top-right-radius: $radius.un-radius--l; 
		        }
		        .form__table-level > .row:first-child > .form__cell {
		            border: none;
		        }
		        .form__table-level .Grid {
		            width: 100%;
		        }
		        .form__table-level .heading-04 {
		            position: relative;
		            top: -8px;
		            inset-inline-start: $spacing.un-m;
		        }
		        .form__toolbar-cell {
		            width: 100%;
		            margin-inline-start: 0;
		            text-align: center;
		            display: flex;
		            justify-content: center;
		        }
		        //error message in Grid column
		        .gx-error__message-container {
		            height: 24px;
		            line-height: 24px;
		            font-family: $fonts.un-font__family;
		            font-size: $fontSizes.un-xs;
		            background-color: $colors.overlay-bg;
		            border-radius: $radius.un-radius--l;
		            box-shadow: $shadows.l;
		            padding-inline-end: $spacing.un-m;
		        }
		
		        @media screen and (max-width: 767px) {
		            .form__actions--fixed {
		                padding-inline-end: 15px;
		            }
		            .form__actions--fixed .gx-action-group {
		                padding-inline-end: $spacing.un-s;
		            }
		            .filters-container {
		                position: unset;
		            }
		            .filters-container--visible {
		                position: fixed;
		                top: 150px;
		                width: calc(100% - 32px);
		                inset-inline-end: 16px;
		            }
		            .body-container .ww__actions-container {
		                margin-bottom: $spacing.un-l;
		            }
		        }
		    #endregion
		
		}
	#End

	#Properties
		Name = "UnanimoWeb"
	#End

}
